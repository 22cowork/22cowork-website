---
import LandingLayout from "../layouts/LandingLayout.astro";
---
<LandingLayout
  title="Commute Calculator, What Lisboa Commuting Really Costs You | 22cowork"
  description="See how many hours and euros you'd reclaim each year by working from 22cowork in Setúbal instead of commuting into Lisboa. Move the sliders and find out."
  slug="commute-calculator"
  ogImg="/assets/parking.jpg"
>
  <!-- HERO + CALCULATOR -->
  <section class="lp-hero">
    <div class="wrap">
      <div class="sec-head" style="max-width:720px;margin-bottom:clamp(28px,4vh,44px)">
        <span class="mono label lp-eyebrow">Commute calculator</span>
        <h2 style="font-size:clamp(2.1rem,4.6vw,3.6rem)">What is the commute<br />into Lisboa really costing you?</h2>
        <p>Every hour in traffic is an hour you don't get back. Move the sliders to see what a year of working from Setúbal instead would give you.</p>
      </div>

      <div class="calc">
        <div class="ctl-wrap">
          <div class="ctl">
            <label>How far you live from work, one way, <strong id="kmVal" style="color:var(--ember)">30</strong> km</label>
            <input class="range" type="range" id="km" min="5" max="90" step="1" value="30" />
          </div>
          <div class="ctl">
            <label>Days you'd commute per week, <strong id="dayVal" style="color:var(--ember)">5</strong></label>
            <input class="range" type="range" id="days" min="1" max="6" step="1" value="5" />
          </div>
          <details class="assump">
            <summary>Costs used, Portugal averages (tap to fine-tune)</summary>
            <div class="ag">
              <div class="ctl"><label>Fuel €/L</label><input type="number" id="fuel" min="0.5" max="3" step="0.01" value="1.88" /></div>
              <div class="ctl"><label>Consumption L/100km</label><input type="number" id="cons" min="2" max="20" step="0.1" value="6.5" /></div>
              <div class="ctl"><label>Avg speed km/h</label><input type="number" id="speed" min="10" max="120" step="1" value="50" /></div>
              <div class="ctl"><label>Tolls €/day</label><input type="number" id="toll" min="0" max="30" step="0.1" value="2.10" /></div>
            </div>
          </details>
          <p class="mono" style="color:rgba(244,241,234,.42);margin:12px 0 0;font-size:.58rem;line-height:1.5">Fuel avg €1.88/L (DGEG, Jul 2026) · ~46 working weeks a year · you can adjust every value above.</p>
        </div>

        <div class="out">
          <div class="lbl">Time you'd reclaim, every year</div>
          <div class="big" id="hoursOut">276<small> hours</small></div>
          <div class="lbl" style="margin-top:1.6rem">Money you'd keep, every year</div>
          <div class="big" id="moneyOut">€2,169</div>
          <p class="sub2" id="daysNote">That's about 17 full waking days back, plus roughly €9 a day in fuel and tolls you'd stop spending. Parking here is free.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM -->
  <section class="sec" style="padding-top:clamp(30px,5vh,56px)">
    <div class="wrap">
      <div class="grid" style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(30px,5vw,72px);align-items:center">
        <div class="sec-head">
          <span class="mono label lp-eyebrow">Turn hours into work</span>
          <h2>Get your numbers, and a plan to reclaim them.</h2>
          <p>We'll email your personal breakdown plus how a desk in Setúbal would fit your week. No spreadsheet homework required.</p>
          <ul class="lp-ticks" style="margin-top:1.6rem">
            <li>Your saved hours and euros, in writing</li>
            <li>A free day pass to try the commute in reverse</li>
            <li>Zero pressure, reply only if it's for you</li>
          </ul>
        </div>

        <form class="lp-form" id="form" data-lead
              data-success="Sent, your commute breakdown is on its way. ✓">
          <input type="hidden" name="source" value="Commute Calculator landing" />
          <input type="hidden" name="offer" value="Commute breakdown + day pass" />
          <input type="hidden" name="distance_km" id="hKm" value="30" />
          <input type="hidden" name="commute_min" id="hCommute" value="36" />
          <input type="hidden" name="days_week" id="hDays" value="5" />
          <input type="hidden" name="hours_saved" id="hHours" value="276" />
          <input type="hidden" name="money_saved" id="hMoney" value="2169" />
          <p class="fh">Email me my results</p>
          <p class="fsub">We'll send your breakdown and a free day pass.</p>
          <div class="f2">
            <div class="field"><label>First name</label><input type="text" name="name" placeholder="Your name" required /></div>
            <div class="field"><label>Phone</label><input type="tel" name="phone" placeholder="+351 …" required /></div>
          </div>
          <div class="field"><label>Email</label><input type="email" name="email" placeholder="you@company.com" required /></div>
          <div class="field"><label>Where do you commute from?</label><input type="text" name="company" placeholder="e.g. Lisboa, Almada, Barreiro" /></div>
          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>I agree to be contacted by 22cowork and I've read the <a href="https://www.22cowork.pt/privacy" target="_blank" rel="noopener">Privacy Policy</a>.</span>
          </label>
          <button type="submit" class="btn btn-gold">Send my breakdown →</button>
          <p class="form-status"></p>
          <p class="form-note">No payment · No obligation</p>
        </form>
      </div>
    </div>
  </section>

  <!-- WHY SETUBAL -->
  <section class="sec" style="padding-top:0">
    <div class="wrap">
      <div class="sec-head">
        <span class="mono label lp-eyebrow">Why it adds up</span>
        <h2>Same work. Half the friction.</h2>
      </div>
      <div class="ben-grid">
        <div class="ben"><span class="n">01</span><h3>The time is real</h3><p>Hours you'd spend in traffic become hours for deep work, family or rest. Nobody gives those back but a shorter commute.</p></div>
        <div class="ben"><span class="n">02</span><h3>The money is real</h3><p>Fuel, tolls and transport add up fast. Working closer to home quietly returns a small salary each year.</p></div>
        <div class="ben"><span class="n">03</span><h3>The setup is better</h3><p>10&nbsp;Gbps fibre, quiet focus rooms and free parking, 35 minutes from Lisboa, none of the daily grind.</p></div>
      </div>
    </div>
  </section>

  <style>
    .assump{margin-top:4px;border-top:1px solid rgba(244,241,234,.14);padding-top:14px}
    .assump summary{font-family:"IBM Plex Mono",monospace;font-size:.6rem;letter-spacing:.11em;text-transform:uppercase;color:rgba(244,241,234,.62);cursor:pointer;list-style:none;user-select:none}
    .assump summary::-webkit-details-marker{display:none}
    .assump summary::before{content:"+  ";color:var(--ember);font-weight:600}
    .assump[open] summary::before{content:"–  "}
    .ag{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}
    .ag .ctl{margin-bottom:0}
  </style>

  <script is:inline>
    (function () {
      var WEEKS = 46;
      var $ = function (id) { return document.getElementById(id); };
      var km = $("km"), days = $("days"), fuel = $("fuel"), cons = $("cons"), speed = $("speed"), toll = $("toll");
      var kmVal = $("kmVal"), dayVal = $("dayVal");
      var hoursOut = $("hoursOut"), moneyOut = $("moneyOut"), daysNote = $("daysNote");
      var hKm = $("hKm"), hCommute = $("hCommute"), hDays = $("hDays"), hHours = $("hHours"), hMoney = $("hMoney");

      function euro(n) { return "€" + Math.round(n).toLocaleString("en-GB"); }

      function update() {
        var K = +km.value, D = +days.value;
        var F = +fuel.value || 0, C = +cons.value || 0, S = +speed.value || 1, T = +toll.value || 0;
        var roundTrip = 2 * K;                       // km per day
        var trips = D * WEEKS;                        // commuting days per year
        var fuelPerDay = roundTrip * (C / 100) * F;   // € fuel per day
        var costPerDay = fuelPerDay + T;              // + tolls
        var money = costPerDay * trips;               // € per year
        var hours = Math.round((roundTrip / S) * trips); // hours per year
        var wakingDays = Math.round(hours / 16);

        kmVal.textContent = K;
        dayVal.textContent = D;
        hoursOut.innerHTML = hours.toLocaleString("en-GB") + "<small> hours</small>";
        moneyOut.textContent = euro(money);
        daysNote.textContent = "That's about " + wakingDays + " full waking days back, plus roughly " +
          euro(costPerDay) + " a day in fuel and tolls you'd stop spending. Parking here is free.";

        hKm.value = K;
        hCommute.value = Math.round((roundTrip / S) * 60 / 2); // approx one-way minutes
        hDays.value = D;
        hHours.value = hours;
        hMoney.value = Math.round(money);
      }
      [km, days, fuel, cons, speed, toll].forEach(function (el) {
        el.addEventListener("input", update);
        el.addEventListener("change", update);
      });
      update();
    })();
  </script>
</LandingLayout>
