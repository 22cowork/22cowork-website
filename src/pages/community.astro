---
import Layout from "../layouts/Layout.astro";
import { communityPageContent, siteMetadata } from "../config/content";
import RevealSection from "../components/RevealSection.jsx";
---

<Layout title={`Community · ${siteMetadata.title}`} description={communityPageContent.hero.description}>
  <section class="relative py-20 bg-soft-off-white">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-display font-bold mb-4 text-text-black">
        {communityPageContent.hero.headline}
      </h1>
      <p class="text-lg md:text-xl text-text-dark-gray max-w-3xl mx-auto">
        {communityPageContent.hero.description}
      </p>
    </div>
  </section>

  {communityPageContent.sections.map((section, index) => (
    <section class={`py-20 ${index % 2 === 0 ? "bg-warm-white" : "bg-soft-off-white"}`}>
      <div class="container">
        <RevealSection client:load>
          <div class={`flex flex-col ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"} items-center gap-12`}>
            <div class="md:w-1/2">
              <img src={section.image} alt={section.title} class="w-full h-auto object-cover rounded-lg shadow-lg" />
            </div>
            <div class="md:w-1/2">
              <h2 class="text-3xl font-display font-bold mb-4 text-text-black">{section.title}</h2>
              <p class="text-lg text-text-dark-gray mb-6">{section.description}</p>
              <ul class="space-y-2 text-text-dark-gray">
                {section.items.map((feature) => (
                  <li class="flex items-center">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5 text-forest-green mr-2"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </RevealSection>
      </div>
    </section>
  ))}

  <section class="py-20 bg-forest-green text-warm-white text-center">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        {communityPageContent.ctaFinal.headline}
      </h2>
      <p class="text-lg mb-8 max-w-3xl mx-auto">
        {communityPageContent.ctaFinal.description}
      </p>
      <a href={communityPageContent.ctaFinal.cta.href} class="btn-primary bg-warm-white text-forest-green hover:bg-light-gray">
        {communityPageContent.ctaFinal.cta.text}
      </a>
    </div>
  </section>
</Layout>
