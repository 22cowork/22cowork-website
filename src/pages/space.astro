---
import Layout from '@/layouts/Layout.astro';
import RevealSection from '@/components/RevealSection.jsx';
import { spacePageContent } from '@/config/content';
import { colors } from '@/config/colors';
import spaceImage from '@/assets/meeting_room.jpg';
---

<Layout
  title="O Espaço - 22Cowork"
  description={spacePageContent.hero.description}
  ogImage={spaceImage.src}
  ogUrl="https://22cowork.pt/space"
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden" style={{ backgroundColor: colors.background }}>
    <div class="container relative z-10 py-20">
      <RevealSection client:load>
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="font-display font-bold mb-6" style={{ color: colors.foreground }}>
            {spacePageContent.hero.headline}
          </h1>
          <p class="text-lg" style={{ color: colors['muted-foreground'] }}>
            {spacePageContent.hero.description}
          </p>
        </div>
      </RevealSection>
    </div>
    <img
      src={spaceImage.src}
      alt="O Espaço"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
  </section>

  <!-- Space Types Section -->
  <section class="py-20">
    <div class="container">
      <h2 class="font-display font-bold text-3xl mb-12 text-center" style={{ color: colors.foreground }}>
        Tipos de Espaço
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {spacePageContent.spaceTypes.map((type, index) => (
          <RevealSection client:load delay={index * 0.1} key={index}>
            <div class="p-8 rounded-lg" style={{ backgroundColor: colors.card, borderLeft: `4px solid ${colors.primary}` }}>
              <h3 class="font-display font-bold mb-3" style={{ color: colors.primary }}>
                {type.title}
              </h3>
              <p style={{ color: colors['muted-foreground'] }}>
                {type.description}
              </p>
              {type.tags && (
                <div class="flex flex-wrap gap-2 mt-4">
                  {type.tags.map((tag) => (
                    <span key={tag} class="text-xs px-2 py-1 rounded" style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}>
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </RevealSection>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20" style={{ backgroundColor: colors.card }}>
    <div class="container">
      <RevealSection client:load>
        <div class="text-center">
          <h2 class="font-display font-bold mb-6" style={{ color: colors.foreground }}>
            {spacePageContent.cta.headline}
          </h2>
          <p class="text-lg mb-8" style={{ color: colors['muted-foreground'] }}>
            {spacePageContent.cta.description}
          </p>
          <a
            href="/book"
            class="inline-block px-8 py-3 rounded-lg font-semibold transition-all hover:scale-105"
            style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}
          >
            {spacePageContent.cta.buttonText}
          </a>
        </div>
      </RevealSection>
    </div>
  </section>
</Layout>
