---
import Layout from '@/layouts/Layout.astro';
import RevealSection from '@/components/RevealSection.jsx';
import { membershipsPageContent } from '@/config/content';
import { colors } from '@/config/colors';
---

<Layout
  title="Membros - 22Cowork"
  description={membershipsPageContent.hero.description}
  ogUrl="https://22cowork.pt/memberships"
>
  <!-- Hero Section -->
  <section class="py-20" style={{ backgroundColor: colors.background }}>
    <div class="container">
      <RevealSection client:load>
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="font-display font-bold mb-6" style={{ color: colors.foreground }}>
            {membershipsPageContent.hero.headline}
          </h1>
          <p class="text-lg" style={{ color: colors['muted-foreground'] }}>
            {membershipsPageContent.hero.description}
          </p>
        </div>
      </RevealSection>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20">
    <div class="container">
      <h2 class="font-display font-bold text-3xl mb-12 text-center" style={{ color: colors.foreground }}>
        Planos de Membros
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {membershipsPageContent.tiers.map((tier, index) => (
          <RevealSection client:load delay={index * 0.1} key={index}>
            <div
              class="p-8 rounded-lg border-2 transition-all hover:scale-105"
              style={{
                backgroundColor: colors.card,
                borderColor: tier.highlighted ? colors.primary : colors.border,
              }}
            >
              <h3 class="font-display font-bold mb-2 text-xl" style={{ color: colors.primary }}>
                {tier.name}
              </h3>
              <p class="text-sm mb-4" style={{ color: colors['muted-foreground'] }}>
                {tier.tagline}
              </p>
              <p class="text-3xl font-bold mb-6" style={{ color: colors.foreground }}>
                €{tier.monthlyPrice}
                <span class="text-sm" style={{ color: colors['muted-foreground'] }}>/mês</span>
              </p>
              <ul class="space-y-3 mb-8">
                {tier.features.map((feature) => (
                  <li style={{ color: colors['muted-foreground'] }} class="text-sm" key={feature}>
                    ✓ {feature}
                  </li>
                ))}
              </ul>
              <a
                href="/book"
                class="block w-full text-center px-4 py-2 rounded-lg font-semibold transition-all"
                style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}
              >
                {tier.cta}
              </a>
            </div>
          </RevealSection>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20" style={{ backgroundColor: colors.card }}>
    <div class="container">
      <RevealSection client:load>
        <div class="text-center">
          <h2 class="font-display font-bold mb-6" style={{ color: colors.foreground }}>
            Pronto para começar?
          </h2>
          <p class="text-lg mb-8" style={{ color: colors['muted-foreground'] }}>
            Todos os planos incluem acesso completo à infraestrutura inteligente do edifício.
          </p>
          <a
            href="/book"
            class="inline-block px-8 py-3 rounded-lg font-semibold transition-all hover:scale-105"
            style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}
          >
            Agendar Visita
          </a>
        </div>
      </RevealSection>
    </div>
  </section>
</Layout>
