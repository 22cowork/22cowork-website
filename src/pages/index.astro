---
import Layout from "../layouts/Layout.astro";
import { homepageContent, siteMetadata } from "../config/content";
import RevealSection from "../components/RevealSection.jsx";
---

<Layout title={siteMetadata.title} description={siteMetadata.description}>
  <section class="relative h-screen flex items-center justify-center text-center bg-cover bg-center" style={{ backgroundImage: `url(${homepageContent.hero.image})` }}>
    <div class="absolute inset-0 bg-black opacity-50"></div>
    <div class="relative z-10 text-warm-white p-4">
      <h1 class="text-4xl md:text-6xl font-display font-bold mb-4 leading-tight">
        {homepageContent.hero.headline}
      </h1>
      <p class="text-lg md:text-xl mb-8 max-w-3xl mx-auto">
        {homepageContent.hero.description}
      </p>
      <div class="flex flex-col sm:flex-row justify-center space-y-4 sm:space-y-0 sm:space-x-4">
        <a href={homepageContent.hero.ctaPrimary.href} class="btn-primary">
          {homepageContent.hero.ctaPrimary.text}
        </a>
        <a href={homepageContent.hero.ctaSecondary.href} class="btn-secondary">
          {homepageContent.hero.ctaSecondary.text}
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-soft-off-white">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-center mb-12">
        {homepageContent.storytelling.title}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        {homepageContent.storytelling.sections.map((section, index) => (
          <RevealSection client:load>
            <div class={`flex flex-col ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"} items-center gap-8`}>
              <div class="md:w-1/2">
                <img src={section.image} alt={section.title} class="w-full h-auto object-cover rounded-lg shadow-lg" />
              </div>
              <div class="md:w-1/2">
                <h3 class="text-2xl font-display font-semibold mb-4">{section.title}</h3>
                <p class="text-lg text-text-dark-gray">{section.description}</p>
              </div>
            </div>
          </RevealSection>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-warm-white">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-center mb-12">
        {homepageContent.valueProposition.title}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {homepageContent.valueProposition.items.map((item) => (
          <RevealSection client:load>
            <div class="flex flex-col items-center text-center p-6 bg-soft-off-white rounded-lg shadow-md">
              <img src={item.icon} alt={item.headline} class="w-16 h-16 mb-4" />
              <h3 class="text-xl font-display font-semibold mb-2">{item.headline}</h3>
              <p class="text-text-dark-gray">{item.description}</p>
            </div>
          </RevealSection>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-green text-warm-white text-center">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        {homepageContent.ctaFinal.headline}
      </h2>
      <p class="text-lg mb-8 max-w-3xl mx-auto">
        {homepageContent.ctaFinal.description}
      </p>
      <div class="flex flex-col sm:flex-row justify-center space-y-4 sm:space-y-0 sm:space-x-4">
        <a href={homepageContent.ctaFinal.ctaPrimary.href} class="btn-primary bg-warm-white text-forest-green hover:bg-light-gray">
          {homepageContent.ctaFinal.ctaPrimary.text}
        </a>
        <a href={homepageContent.ctaFinal.ctaSecondary.href} class="btn-secondary border-warm-white text-warm-white hover:bg-warm-white hover:text-forest-green">
          {homepageContent.ctaFinal.ctaSecondary.text}
        </a>
      </div>
    </div>
  </section>
</Layout>
