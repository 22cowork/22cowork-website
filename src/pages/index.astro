---
import Layout from '@/layouts/Layout.astro';
import RevealSection from '@/components/RevealSection.jsx';
import { homepageContent } from '@/config/content';
import { colors } from '@/config/colors';
import heroImage from '@/assets/hero_space.jpg';
---

<Layout
  title="22Cowork - O Espaço de Trabalho Mais Inteligente da Europa"
  description={homepageContent.hero.description}
  ogImage={heroImage.src}
  ogUrl="https://22cowork.pt"
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden" style={{ backgroundColor: colors.background }}>
    <div class="container relative z-10 py-20">
      <RevealSection client:load>
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-sm font-mono mb-4 uppercase tracking-widest" style={{ color: colors.primary }}>
            {homepageContent.hero.tagline}
          </p>
          <h1 class="font-display font-bold mb-6" style={{ color: colors.foreground }}>
            {homepageContent.hero.headline}
          </h1>
          <p class="text-lg mb-8" style={{ color: colors['muted-foreground'] }}>
            {homepageContent.hero.description}
          </p>
          <a
            href="/book"
            class="inline-block px-8 py-3 rounded-lg font-semibold transition-all hover:scale-105"
            style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}
          >
            {homepageContent.hero.ctaPrimary}
          </a>
        </div>
      </RevealSection>
    </div>
    <img
      src={heroImage.src}
      alt="22Cowork Space"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
  </section>

  <!-- Philosophy Section -->
  <section class="py-20" style={{ backgroundColor: colors.card }}>
    <div class="container">
      <RevealSection client:load>
        <div class="max-w-2xl mx-auto text-center" set:html={homepageContent.philosophyStrip.text}>
        </div>
      </RevealSection>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {homepageContent.stats.map((stat, index) => (
          <RevealSection client:load delay={index * 0.1} key={index}>
            <div class="text-center p-8 rounded-lg" style={{ backgroundColor: colors.card }}>
              <p class="text-4xl font-display font-bold mb-2" style={{ color: colors.primary }}>
                {stat.value}{stat.suffix}
              </p>
              <p style={{ color: colors['muted-foreground'] }}>
                {stat.label}
              </p>
            </div>
          </RevealSection>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20" style={{ backgroundColor: colors.card }}>
    <div class="container">
      <RevealSection client:load>
        <div class="text-center">
          <h2 class="font-display font-bold mb-6" style={{ color: colors.foreground }}>
            {homepageContent.cta.headline}
          </h2>
          <p class="text-lg mb-8" style={{ color: colors['muted-foreground'] }}>
            {homepageContent.cta.description}
          </p>
          <a
            href="/book"
            class="inline-block px-8 py-3 rounded-lg font-semibold transition-all hover:scale-105"
            style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}
          >
            {homepageContent.cta.buttonText}
          </a>
        </div>
      </RevealSection>
    </div>
  </section>
</Layout>
