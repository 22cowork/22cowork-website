---
import HomeLayout from "../layouts/HomeLayout.astro";
const maps = "https://www.google.com/maps/search/?api=1&query=22cowork&query_place_id=ChIJibrR-YpDGQ0R2UrFT6Fufsk";
---

<HomeLayout>
  <!-- NAV -->
  <header class="nav" id="nav">
    <a href="#top" class="brand"><b>22cowork</b></a>
    <nav class="links">
      <a href="#spaces">Spaces</a>
      <a href="#work">A day here</a>
      <a href="#spec">Building</a>
      <a href="/blog">Journal</a>
      <a href="#reserve" class="nav-cta">Reserve</a>
    </nav>
    <a href="#reserve" class="burger">Reserve</a>
  </header>

  <!-- HERO -->
  <section class="hero" id="top">
    <img class="hero-img" src="/assets/hero.jpg" srcset="/assets/hero-mobile.jpg 800w, /assets/hero.jpg 1400w" sizes="100vw" width="1400" height="933" fetchpriority="high" decoding="async" alt="Inside 22cowork, Setúbal" />
    <div class="scrim"></div>

    <div class="hero-inner wrap">
      <h1 class="display">A coworking space for<br />people who <span class="rot-hold"><em id="rot" class="rot">ship, not sit.</em><span class="cursor"></span></span></h1>
      <p class="sub">Dedicated desks and private offices, a soundproofed studio and a gym downstairs. In Setúbal, 35 minutes from Lisboa.</p>
      <div class="hero-actions">
        <a href="#reserve" class="btn btn-gold">Reserve your space →</a>
        <a href="#tour" class="btn btn-ghost">Take the tour</a>
      </div>
    </div>

    <div class="scroll-cue"><span>Scroll</span><span class="ln"></span></div>
  </section>

  <!-- TRUST BAND -->
  <div class="trust">
    <div class="wrap">
      <a class="grating" href={maps} target="_blank" rel="noopener">
        <span class="stars">★★★★★</span>
        <span class="gr-txt"><b>5.0</b> · 21 Google reviews</span>
      </a>
      <div class="stat"><b>35 min</b><span>from Lisboa</span></div>
      <div class="stat"><b>24/7</b><span>keycard access</span></div>
      <div class="stat"><b>10GB</b><span>fibre + WiFi 7</span></div>
      <div class="stat"><b>Parking</b><span>private, underground</span></div>
    </div>
  </div>

  <!-- CHOOSE YOUR SPACE + TOUR (side by side) -->
  <section class="band spaces" id="spaces">
    <div class="wrap">
      <div class="spaces-head">
        <div class="sh-text">
          <h2 class="h2 rise">Choose your space.</h2>
          <p class="lead rise" data-d="1">Five ways to work here, from a desk for the day to your own office. Reserve the one that fits and we'll confirm within a day.</p>
          <div class="rise" data-d="2" style="margin-top:1.7rem"><a href="#reserve" class="btn btn-gold">Reserve your space →</a></div>
        </div>
        <div class="sh-video rise" data-d="1" id="tour">
          <div class="video-frame" id="tour-video" data-yt="htTdP9zs7pM">
            <button class="vplay" type="button" aria-label="Play the 22cowork tour">
              <img loading="lazy" decoding="async" class="vthumb" src="https://i.ytimg.com/vi/htTdP9zs7pM/maxresdefault.jpg" alt="22cowork office tour" />
              <span class="vbtn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg></span>
            </button>
          </div>
          <div style="margin-top:12px"><a href="https://www.youtube.com/watch?v=htTdP9zs7pM" target="_blank" rel="noopener" class="mono label">Prefer YouTube? Watch the tour there ↗</a></div>
        </div>
      </div>

      <div class="sp-grid">
        <a href="#reserve" class="sp-card feat rise">
          <div class="sp-media"><span class="sp-badge">Most popular</span><img loading="lazy" decoding="async" src="/assets/deepwork.jpg" alt="Dedicated desk at 22cowork" /></div>
          <div class="sp-body">
            <h3>Dedicated Desk</h3>
            <p>Your own wood desk and ergonomic chair, same spot every day. The default for founders here full time.</p>
            <span class="sp-go">Reserve a desk →</span>
          </div>
        </a>

        <a href="#reserve" class="sp-card feat rise" data-d="1">
          <div class="sp-media"><span class="sp-badge">Opening Sept 2026</span><img loading="lazy" decoding="async" src="/assets/meeting.jpg" alt="Private office at 22cowork" /></div>
          <div class="sp-body">
            <h3>Private Office</h3>
            <p>Natural light, your team, your layout, a door that closes. In presale now, opening September 2026.</p>
            <span class="sp-go">Reserve an office →</span>
          </div>
        </a>

        <a href="#reserve" class="sp-card rise">
          <div class="sp-media"><span class="sp-badge soft">Flexible</span><img loading="lazy" decoding="async" src="/assets/arrival.jpg" alt="Hot desk lounge at 22cowork" /></div>
          <div class="sp-body">
            <h3>Hot Desk</h3>
            <p>Any open desk, any day. For remote workers and freelancers who want flexibility.</p>
            <span class="sp-go">Reserve →</span>
          </div>
        </a>

        <a href="#reserve" class="sp-card rise" data-d="1">
          <div class="sp-media"><span class="sp-badge soft">By the hour</span><img loading="lazy" decoding="async" src="/assets/studio.jpg" alt="Meeting and podcast studio at 22cowork" /></div>
          <div class="sp-body">
            <h3>Meeting &amp; Studio</h3>
            <p>A closed room for client calls, plus a podcast &amp; content studio. Book it by the hour.</p>
            <span class="sp-go">Reserve →</span>
          </div>
        </a>

        <a href="#reserve" class="sp-card rise" data-d="2">
          <div class="sp-media"><span class="sp-badge soft">No desk needed</span><img loading="lazy" decoding="async" src="/assets/post.jpg" alt="Post handling at 22cowork" /></div>
          <div class="sp-body">
            <h3>Business Address</h3>
            <p>A real Setúbal business address with mail handling, whether or not you have a desk here.</p>
            <span class="sp-go">Reserve →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FREE DAY PASS CTA -->
  <section class="band daypass-cta">
    <div class="wrap">
      <div class="dpc rise">
        <div class="dpc-text">
          <span class="mono label">Free day pass</span>
          <h2>Not sure yet? Spend a day here, on us.</h2>
          <p>No card, no commitment. A real desk, 10GB fibre and free parking for a full day. The surest way to know if it fits.</p>
        </div>
        <a href="/day-pass" class="btn btn-gold">Claim your free day →</a>
      </div>
    </div>
  </section>

  <!-- MANIFESTO -->
  <section class="band manifesto" id="space">
    <div class="wrap">
      <p class="quote rise">Fancy fails. <span class="em">Simple scales.</span></p>
      <div class="foot rise" data-d="1">
        <p>No gimmicks. No beanbag theatre. A solid room, a fast connection, and people who are actually working.</p>
      </div>
    </div>
  </section>

  <!-- SPEC SHEET, what's in the building -->
  <section class="band spec" id="spec">
    <div class="wrap">
      <div class="rise" style="margin-bottom:1.2rem"><span class="status" style="float:none"><span class="dot"></span>Systems online</span></div>
      <h2 class="h2 rise" data-d="1">What's actually<br />in the building.</h2>
      <div class="sheet">
        <div class="row rise"><span class="k">Net</span><span class="v">10GB fibre backbone, WiFi 7 throughout</span><span class="m">//</span></div>
        <div class="row rise"><span class="k">Access</span><span class="v">24 hour keycard entry</span><span class="m">//</span></div>
        <div class="row rise"><span class="k">Studio</span><span class="v">Soundproofed podcast &amp; content room</span><span class="m">//</span></div>
        <div class="row rise"><span class="k">Fitness</span><span class="v">Gym downstairs, Fitness Up</span><span class="m">//</span></div>
        <div class="row rise"><span class="k">Parking</span><span class="v">Private, underground</span><span class="m">//</span></div>
        <div class="row rise"><span class="k">Post</span><span class="v">Business address + mail handling</span><span class="m">//</span></div>
        <div class="row rise"><span class="k">Coffee</span><span class="v">Included, always</span><span class="m">//</span></div>
      </div>
    </div>
  </section>

  <!-- A DAY HERE, COMPACT DAY RAIL -->
  <section class="band day" id="work">
    <div class="wrap">
      <div class="day-head rise">
        <span class="mono label">A day here</span>
        <h2 class="h2">One good day, on repeat.</h2>
        <p class="lead">Park underground at 08:00, gym downstairs by 17:45. The whole day handled, in one building.</p>
      </div>
      <div class="dayrail-wrap rise" data-d="1">
        <svg class="vine" viewBox="0 0 1200 72" fill="none" preserveAspectRatio="none" aria-hidden="true">
          <path class="stem" d="M8,46 C170,14 250,60 410,42 C560,25 660,62 820,44 C960,28 1060,60 1192,42" />
          <g class="leaves">
            <path class="lf" transform="translate(150 30) rotate(-20)" d="M0,0 C7,-4 12,-13 6,-23 C2,-28 -2,-28 -6,-23 C-12,-13 -7,-4 0,0 Z" />
            <path class="lf" transform="translate(360 50) rotate(18)" d="M0,0 C7,-4 12,-13 6,-23 C2,-28 -2,-28 -6,-23 C-12,-13 -7,-4 0,0 Z" />
            <path class="lf" transform="translate(560 26) rotate(-14)" d="M0,0 C7,-4 12,-13 6,-23 C2,-28 -2,-28 -6,-23 C-12,-13 -7,-4 0,0 Z" />
            <path class="lf" transform="translate(770 52) rotate(22)" d="M0,0 C7,-4 12,-13 6,-23 C2,-28 -2,-28 -6,-23 C-12,-13 -7,-4 0,0 Z" />
            <path class="lf" transform="translate(985 28) rotate(-18)" d="M0,0 C7,-4 12,-13 6,-23 C2,-28 -2,-28 -6,-23 C-12,-13 -7,-4 0,0 Z" />
          </g>
        </svg>
        <ol class="dayrail">
          <li class="stop"><span class="thumb"><img loading="lazy" decoding="async" src="/assets/parking.jpg" alt="Underground parking at 22cowork" /></span><div class="s-body"><span class="t">08:00</span><h3>Park underground</h3><p>Your spot, every day. No circling, no meter.</p></div></li>
          <li class="stop"><span class="thumb"><img loading="lazy" decoding="async" src="/assets/coffee.jpg" alt="Coffee at 22cowork" /></span><div class="s-body"><span class="t">08:20</span><h3>First coffee</h3><p>The good machine, not the sad pod. Always on.</p></div></li>
          <li class="stop"><span class="thumb"><img loading="lazy" decoding="async" src="/assets/deepwork.jpg" alt="Dedicated desk at 22cowork" /></span><div class="s-body"><span class="t">09:00</span><h3>Deep work</h3><p>Your desk, 10GB fibre, quiet that holds.</p></div></li>
          <li class="stop"><span class="thumb"><img loading="lazy" decoding="async" src="/assets/studio.jpg" alt="Podcast and content studio at 22cowork" /></span><div class="s-body"><span class="t">14:00</span><h3>Record it</h3><p>Soundproofed studio, same building.</p></div></li>
          <li class="stop"><span class="thumb"><img loading="lazy" decoding="async" src="/assets/gym.jpg" alt="Gym at 22cowork" /></span><div class="s-body"><span class="t">17:45</span><h3>Gym downstairs</h3><p>Close the laptop, not the day.</p></div></li>
        </ol>
      </div>
    </div>
  </section>

  <!-- COMMUNITY -->
  <section class="band comm">
    <div class="wrap comm-grid">
      <div>
        <h2 class="h2 rise">Not a lobby<br />full of strangers.</h2>
        <p class="lead rise" data-d="1" style="margin-top:1.4rem">Follow the building day to day. Who's shipped what, which desks are open, what's on this month.</p>
        <div class="rise" data-d="1" style="margin-top:2rem"><a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="btn btn-outline">@22cowork on Instagram →</a></div>
      </div>
      <div class="ig rise" data-d="1" id="ig-feed">
        <a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="slot"><img loading="lazy" decoding="async" src="/assets/ig1.jpg" alt="22cowork" /><span class="tag">@22cowork</span></a>
        <a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="slot"><img loading="lazy" decoding="async" src="/assets/ig2.jpg" alt="22cowork" /></a>
        <a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="slot"><img loading="lazy" decoding="async" src="/assets/ig3.jpg" alt="22cowork" /></a>
        <a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="slot"><img loading="lazy" decoding="async" src="/assets/ig4.jpg" alt="22cowork" /></a>
        <a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="slot"><img loading="lazy" decoding="async" src="/assets/ig5.jpg" alt="22cowork" /></a>
        <a href="https://instagram.com/22cowork" target="_blank" rel="noopener" class="slot"><img loading="lazy" decoding="async" src="/assets/studio.jpg" alt="22cowork" /></a>
      </div>
    </div>
  </section>

  <!-- RESERVE -->
  <section class="contact" id="reserve">
    <div class="wrap">
      <div class="grid">
        <div class="rise" data-d="1">
          <span class="mono label">Reserve your space</span>
          <h2 class="h2" style="margin-top:1rem">Claim your spot before it's taken.</h2>
          <div class="mono label" style="margin-top:2.2rem"><a href={maps} target="_blank" rel="noopener">View on Google Maps ↗</a></div>
          <div style="margin-top:1rem" class="mono label"><a href="mailto:team@22cowork.pt">team@22cowork.pt</a></div>
          <div class="mono" style="margin-top:1.6rem; color:rgba(244,241,234,.45)">Pricing shared with your reservation. We compete on value, not tiers.</div>
        </div>
        <form class="rise" data-d="2" id="lead-form">
          <div class="f2">
            <div class="field"><label>Full name</label><input type="text" name="name" placeholder="Your name" required /></div>
            <div class="field"><label>Email</label><input type="email" name="email" placeholder="you@company.com" required /></div>
          </div>
          <div class="f2">
            <div class="field"><label>Phone</label><input type="tel" name="phone" placeholder="+351 …" required /></div>
            <div class="field"><label>Company</label><input type="text" name="company" placeholder="Optional" /></div>
          </div>
          <div class="field">
            <label>What are you after</label>
            <select name="interest" required>
              <option value="">Choose…</option>
              <option>Dedicated Desk</option>
              <option>Private Office (Sept 2026)</option>
              <option>Hot Desk</option>
              <option>Meeting / Studio Room</option>
              <option>Business Address</option>
              <option>Just looking</option>
            </select>
          </div>
          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>I agree to be contacted by 22cowork, including marketing communications. See our <a href="/privacy">Privacy Policy</a>.</span>
          </label>
          <button type="submit" class="btn btn-gold" style="justify-self:start; margin-top:6px">Reserve your space →</button>
          <p id="form-status" class="mono" role="status" aria-live="polite" style="display:none; margin-top:14px; color:var(--ember)"></p>
        </form>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="foot">
    <div class="wrap">
      <div class="foot-top">
        <div>
          <div class="big-brand">22cowork<span style="color:#8FC0A9">.</span></div>
          <p style="max-width:34ch; margin-top:1rem; color:var(--muted-2)">A workspace for founders, creators and freelancers. Setúbal, Portugal. 35 minutes from Lisboa.</p>
          <a class="grating foot-rating" href={maps} target="_blank" rel="noopener">
            <span class="stars">★★★★★</span>
            <span class="gr-txt"><b>5.0</b> · 21 Google reviews</span>
          </a>
        </div>
        <div>
          <h4>Space</h4>
          <a href="#spaces">Spaces</a><a href="#work">A day here</a><a href="#spec">The building</a><a href="#tour">Tour</a>
        </div>
        <div>
          <h4>Company</h4>
          <a href="/blog">Journal</a><a href="#reserve">Reserve a space</a><a href="https://instagram.com/22cowork" target="_blank" rel="noopener">Instagram</a>
        </div>
        <div>
          <h4>Legal</h4>
          <a href="/privacy">Privacy Policy</a><a href="https://22cowork.netlify.app/terms" target="_blank" rel="noopener">Terms</a>
        </div>
      </div>
      <div class="foot-bottom">
        <span class="mono">© 2026 22cowork · Setúbal, Portugal</span>
        <span class="mono">Built simple. Made to last.</span>
      </div>
    </div>
  </footer>
</HomeLayout>
