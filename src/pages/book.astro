---
import Layout from "../layouts/Layout.astro";
import { bookPageContent, siteMetadata } from "../config/content";
import RevealSection from "../components/RevealSection.jsx";
import BookForm from "../components/BookForm.jsx";
---

<Layout title={`Book a Tour · ${siteMetadata.title}`} description={bookPageContent.hero.description}>
  <section class="relative py-20 bg-soft-off-white">
    <div class="container text-center">
      <h1 class="text-4xl md:text-5xl font-display font-bold mb-4 text-text-black">
        {bookPageContent.hero.headline}
      </h1>
      <p class="text-lg md:text-xl text-text-dark-gray max-w-3xl mx-auto">
        {bookPageContent.hero.description}
      </p>
    </div>
  </section>

  <section class="py-20 bg-warm-white">
    <div class="container">
      <div class="max-w-2xl mx-auto p-8 rounded-lg shadow-lg bg-soft-off-white">
        <h2 class="text-3xl font-display font-bold text-center mb-8 text-text-black">
          {bookPageContent.form.title}
        </h2>
        <BookForm client:load />
      </div>
    </div>
  </section>

  <section class="py-20 bg-forest-green text-warm-white text-center">
    <div class="container">
      <h2 class="text-3xl md:text-4xl font-display font-bold mb-4">
        {bookPageContent.ctaFinal.headline}
      </h2>
      <p class="text-lg mb-8 max-w-3xl mx-auto">
        {bookPageContent.ctaFinal.description}
      </p>
      <a href="/book" class="btn-primary bg-warm-white text-forest-green hover:bg-light-gray">
        Schedule Your Tour
      </a>
    </div>
  </section>
</Layout>
