---
export interface Props {
  title: string;
  description: string;
  slug: string;            // e.g. "day-pass"
  ogImg?: string;          // absolute path like /assets/hero.jpg
}
const { title, description, slug, ogImg = "/assets/hero.jpg" } = Astro.props;

const SITE = "https://www.22cowork.pt";
const canonical = `${SITE}/${slug.replace(/^\//, "")}`;
const ogImage = `${SITE}${ogImg}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-W54DF8WLWQ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-W54DF8WLWQ');
  </script>

  <!-- Meta Pixel -->
  <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '2897945933870831');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=2897945933870831&ev=PageView&noscript=1" /></noscript>
  <!-- End Meta Pixel -->

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="22cowork" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&amp;family=Inter:wght@400;500;600&amp;family=IBM+Plex+Mono:wght@400;500&amp;family=Montserrat:wght@500;600;700&amp;display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&amp;family=Inter:wght@400;500;600&amp;family=IBM+Plex+Mono:wght@400;500&amp;family=Montserrat:wght@500;600;700&amp;display=swap"
    />
  </noscript>

  <style is:global>
  :root{
    --paper:#F6F7F2; --paper-2:#EAEDE3; --paper-3:#DDE2D3;
    --ink:#171511; --ink-soft:#3A362D; --muted-2:#7D7869;
    --line:rgba(23,21,17,.14); --line-2:rgba(23,21,17,.08);
    --ember:#335C4A; --ember-deep:#294A3B; --contrast:#0B0A08;
    --ease:cubic-bezier(.22,.61,.36,1); --pad:clamp(20px,5vw,88px);
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:"Inter",system-ui,sans-serif;font-size:17px;line-height:1.6;letter-spacing:-.005em;overflow-x:hidden}
  ::selection{background:var(--ink);color:var(--paper)}
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}
  .wrap{max-width:1320px;margin:0 auto;padding:0 var(--pad)}
  .mono{font-family:"IBM Plex Mono",monospace;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2)}
  .label{display:inline-flex;align-items:center;gap:.6em}
  .label::before{content:"";width:16px;height:1px;background:var(--muted-2);display:inline-block}

  /* nav, slim, conversion-focused */
  header.nav{position:sticky;top:0;z-index:60;display:flex;align-items:center;justify-content:space-between;padding:15px var(--pad);background:color-mix(in srgb,var(--paper) 86%,transparent);backdrop-filter:saturate(1.2) blur(14px);border-bottom:1px solid var(--line-2)}
  .brand{font-family:"Montserrat",sans-serif;font-weight:700;font-size:1.12rem;letter-spacing:-.01em}
  nav.links{display:flex;gap:24px;align-items:center}
  nav.links a{font-family:"IBM Plex Mono",monospace;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;opacity:.85;transition:opacity .3s}
  nav.links a:hover{opacity:1}
  .nav-cta{border:1px solid var(--ink);border-radius:100px;padding:9px 18px;transition:.3s}
  .nav-cta:hover{background:var(--ember);border-color:var(--ember);color:#F4F1EA}
  @media(max-width:720px){nav.links a:not(.nav-cta){display:none}}

  .btn{font-family:"IBM Plex Mono",monospace;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;padding:15px 28px;border-radius:100px;border:1px solid;display:inline-flex;align-items:center;gap:.6em;cursor:pointer;transition:transform .4s var(--ease),background .3s}
  .btn:hover{transform:translateY(-2px)}
  .btn-gold{background:var(--ember);color:#F4F1EA;border-color:var(--ember);font-weight:500}
  .btn-gold:hover{background:#3f7059;border-color:#3f7059}
  .btn-ghost{background:transparent;border-color:var(--ink);color:var(--ink)}
  .btn-ghost:hover{background:var(--ink);color:var(--paper)}

  /* hero, split copy + form */
  .lp-hero{padding:clamp(34px,6vh,72px) 0 clamp(30px,5vh,56px)}
  .lp-hero .grid{display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(30px,5vw,72px);align-items:center}
  .lp-eyebrow{color:var(--ember-deep);margin-bottom:1.4rem}
  .lp-eyebrow::before{background:var(--ember-deep)}
  .lp-hero h1{font-family:"Fraunces",serif;font-weight:340;letter-spacing:-.022em;line-height:1.04;font-size:clamp(2.3rem,5vw,3.9rem);margin:0}
  .lp-hero h1 em{font-style:italic;color:var(--ember-deep)}
  .lp-hero .sub{font-size:clamp(1.08rem,1.5vw,1.28rem);color:var(--ink-soft);margin:1.3rem 0 0;max-width:46ch}
  .lp-ticks{list-style:none;padding:0;margin:1.8rem 0 0;display:flex;flex-direction:column;gap:.7rem}
  .lp-ticks li{display:flex;gap:.7rem;align-items:flex-start;color:var(--ink-soft);font-size:1rem}
  .lp-ticks li::before{content:"";flex:none;margin-top:.5em;width:7px;height:7px;border-radius:50%;background:var(--ember)}

  /* form card */
  .lp-form{background:var(--paper-2);border:1px solid var(--line);border-radius:14px;padding:clamp(24px,3vw,36px);box-shadow:0 40px 80px -60px rgba(23,21,17,.5)}
  .lp-form .fh{font-family:"Fraunces",serif;font-weight:380;font-size:1.5rem;letter-spacing:-.015em;margin:0}
  .lp-form .fsub{color:var(--muted-2);font-size:.95rem;margin:.4rem 0 1.4rem}
  .field{display:flex;flex-direction:column;gap:6px;margin-bottom:14px}
  .field label{font-family:"IBM Plex Mono",monospace;font-size:.64rem;letter-spacing:.13em;text-transform:uppercase;color:var(--muted-2)}
  .field input,.field select{font-family:"Inter",sans-serif;font-size:1rem;color:var(--ink);background:var(--paper);border:1px solid var(--line);border-radius:8px;padding:12px 14px;transition:border-color .25s,box-shadow .25s}
  .field input:focus,.field select:focus{outline:none;border-color:var(--ember);box-shadow:0 0 0 3px rgba(51,92,74,.20)}
  .field input::placeholder{color:#a49e8e}
  .f2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .consent{display:flex;gap:10px;align-items:flex-start;margin:6px 0 18px;font-size:.82rem;color:var(--muted-2);line-height:1.5}
  .consent input{margin-top:3px;flex:none;width:16px;height:16px;accent-color:var(--ember-deep)}
  .consent a{color:var(--ember-deep);text-decoration:underline;text-underline-offset:2px}
  .lp-form button{width:100%;justify-content:center}
  .form-status{font-family:"IBM Plex Mono",monospace;font-size:.74rem;letter-spacing:.06em;margin:14px 0 0;text-align:center;display:none}
  .form-note{font-family:"IBM Plex Mono",monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted-2);text-align:center;margin:14px 0 0}
  .lp-download{display:none;margin-top:18px;text-align:center}
  .lp-download .btn{width:100%;justify-content:center}
  .dl-alt{display:inline-block;margin-top:12px;font-family:"IBM Plex Mono",monospace;font-size:.66rem;letter-spacing:.06em;color:var(--ember-deep);text-decoration:underline;text-underline-offset:3px}

  /* proof band */
  .lp-proof{border-top:1px solid var(--line-2);border-bottom:1px solid var(--line-2);background:var(--paper-2)}
  .lp-proof .in{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:clamp(14px,3vw,40px);padding:22px 0}
  .stars{color:var(--ember);letter-spacing:2px;font-size:1rem}
  .lp-proof .txt{font-family:"IBM Plex Mono",monospace;font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft)}

  /* section */
  .sec{padding:clamp(48px,8vh,104px) 0}
  .sec-head{max-width:640px}
  .sec-head h2{font-family:"Fraunces",serif;font-weight:350;letter-spacing:-.02em;line-height:1.08;font-size:clamp(1.9rem,3.8vw,3rem);margin:.7rem 0 0}
  .sec-head p{color:var(--ink-soft);font-size:1.1rem;margin-top:1rem}

  /* benefits grid */
  .ben-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:clamp(32px,5vh,56px)}
  .ben{background:var(--paper-2);border:1px solid var(--line);border-radius:12px;padding:28px 26px}
  .ben .n{font-family:"IBM Plex Mono",monospace;font-size:.66rem;letter-spacing:.12em;color:var(--ember-deep)}
  .ben h3{font-family:"Fraunces",serif;font-weight:400;font-size:1.3rem;margin:.9rem 0 .5rem}
  .ben p{color:var(--ink-soft);font-size:.96rem;margin:0}
  @media(max-width:820px){.ben-grid{grid-template-columns:1fr}}

  /* steps */
  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;margin-top:clamp(32px,5vh,56px)}
  .step{position:relative;padding-top:26px;border-top:2px solid var(--line)}
  .step .num{font-family:"Fraunces",serif;font-style:italic;font-size:2.4rem;color:var(--ember);line-height:1}
  .step h3{font-family:"Fraunces",serif;font-weight:420;font-size:1.2rem;margin:.7rem 0 .4rem}
  .step p{color:var(--ink-soft);font-size:.95rem;margin:0}
  @media(max-width:820px){.steps{grid-template-columns:1fr}}

  /* calculator */
  .calc{background:var(--contrast);color:var(--paper);border-radius:16px;padding:clamp(26px,4vw,44px);display:grid;grid-template-columns:1fr 1fr;gap:clamp(26px,4vw,52px);align-items:center}
  .calc .ctl label{font-family:"IBM Plex Mono",monospace;font-size:.64rem;letter-spacing:.13em;text-transform:uppercase;color:rgba(244,241,234,.6)}
  .calc .ctl{display:flex;flex-direction:column;gap:8px;margin-bottom:18px}
  .calc select,.calc input[type=number]{font-family:"Inter",sans-serif;font-size:1rem;color:var(--paper);background:rgba(244,241,234,.06);border:1px solid rgba(244,241,234,.18);border-radius:8px;padding:12px 14px}
  .calc select:focus,.calc input:focus{outline:none;border-color:var(--ember)}
  .calc select option{color:#171511}
  .calc .range{width:100%;accent-color:var(--ember)}
  .calc .out{border-left:1px solid rgba(244,241,234,.14);padding-left:clamp(20px,3vw,44px)}
  .calc .out .lbl{font-family:"IBM Plex Mono",monospace;font-size:.64rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,241,234,.55)}
  .calc .out .big{font-family:"Fraunces",serif;font-weight:340;font-size:clamp(2.6rem,6vw,4.2rem);line-height:1;color:var(--ember);margin:.3rem 0 0}
  .calc .out .big small{font-size:1.1rem;color:var(--paper);font-family:"Inter",sans-serif;letter-spacing:0}
  .calc .out .sub2{color:rgba(244,241,234,.7);font-size:.95rem;margin:1.4rem 0 0;max-width:34ch}
  @media(max-width:800px){.calc{grid-template-columns:1fr}.calc .out{border-left:0;border-top:1px solid rgba(244,241,234,.14);padding-left:0;padding-top:26px}}

  /* final CTA band */
  .cta-band{background:var(--contrast);color:var(--paper);border-radius:16px;padding:clamp(34px,5vw,64px);text-align:center;margin:0 auto;max-width:820px}
  .cta-band h2{font-family:"Fraunces",serif;font-weight:340;font-size:clamp(1.8rem,3.6vw,2.8rem);letter-spacing:-.02em;margin:0}
  .cta-band p{color:rgba(244,241,234,.72);margin:1rem auto 2rem;max-width:46ch}

  /* footer */
  footer.foot{background:var(--paper);border-top:1px solid var(--line);padding:clamp(38px,5vh,60px) 0 40px;margin-top:clamp(40px,7vh,90px)}
  footer.foot{background:#294A3B;border-top:none;color:#F4F1EA}
  footer.foot .big-brand{color:#F4F1EA}
  footer.foot h4{color:rgba(244,241,234,.5)}
  footer.foot a{color:rgba(244,241,234,.78)}
  footer.foot a:hover{color:#F4F1EA}
  footer.foot p{color:rgba(244,241,234,.74)!important}
  footer.foot .foot-bottom{border-top-color:rgba(244,241,234,.15)}
  footer.foot .mono{color:rgba(244,241,234,.5)}
  .foot-top{display:grid;grid-template-columns:2fr 1fr 1fr;gap:30px}
  .foot h4{font-family:"IBM Plex Mono",monospace;font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2);margin:0 0 14px;font-weight:500}
  .foot a{display:block;font-size:.92rem;color:var(--ink-soft);padding:5px 0}
  .foot a:hover{color:var(--ink)}
  .foot .big-brand{font-family:"Montserrat",sans-serif;font-size:clamp(2rem,5vw,3rem);font-weight:700;letter-spacing:-.02em;line-height:1}
  .foot-bottom{display:flex;justify-content:space-between;margin-top:clamp(30px,4vh,48px);padding-top:22px;border-top:1px solid var(--line-2);flex-wrap:wrap;gap:14px}
  @media(max-width:700px){.foot-top{grid-template-columns:1fr 1fr}}

  @media(max-width:860px){.lp-hero .grid{grid-template-columns:1fr}.lp-form{order:2}}
  </style>
</head>
<body>
  <header class="nav">
    <a href="/" class="brand">22cowork</a>
    <nav class="links">
      <a href="/#spaces">Spaces</a>
      <a href="/blog">Journal</a>
      <a href="#form" class="nav-cta">Get started</a>
    </nav>
  </header>

  <slot />

  <footer class="foot">
    <div class="wrap">
      <div class="foot-top">
        <div>
          <div class="big-brand">22cowork<span style="color:#8FC0A9">.</span></div>
          <p style="max-width:34ch;margin-top:1rem;color:var(--muted-2)">A workspace for founders, creators and freelancers. Setúbal, Portugal. 35 minutes from Lisboa.</p>
        </div>
        <div>
          <h4>Space</h4>
          <a href="/#spaces">Spaces</a><a href="/#work">A day here</a><a href="/blog">Journal</a><a href="/#reserve">Reserve</a>
        </div>
        <div>
          <h4>Legal</h4>
          <a href="/privacy">Privacy Policy</a><a href="https://instagram.com/22cowork" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
      <div class="foot-bottom">
        <span class="mono">© 2026 22cowork · Setúbal, Portugal</span>
        <span class="mono">Built simple. Made to last.</span>
      </div>
    </div>
  </footer>

  <script is:inline>
    // Shared lead-form handler for all landing pages.
    // Any <form data-lead> posts to the same Make webhook -> GoHighLevel.
    // Each form carries a hidden `source` so GHL segments leads per landing page.
    (function () {
      var WEBHOOK = "https://hook.eu1.make.com/1a3pshrwijhoot1p7n3r67dxsj5gs5xz";
      var forms = document.querySelectorAll("form[data-lead]");
      forms.forEach(function (form) {
        var status = form.querySelector(".form-status");
        form.addEventListener("submit", function (e) {
          e.preventDefault();
          var data = Object.fromEntries(new FormData(form).entries());
          data.consent = form.querySelector('input[name="consent"]:checked') ? "yes" : "no";
          data.page = location.pathname;
          var btn = form.querySelector('button[type="submit"]');
          if (btn) { btn.disabled = true; btn.dataset.label = btn.textContent; btn.textContent = "Sending…"; }
          fetch(WEBHOOK, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: new URLSearchParams(data).toString()
          }).then(function () {
            if (status) {
              status.style.display = "block";
              status.style.color = "var(--ember-deep)";
              status.textContent = form.dataset.success || "Done, we'll be in touch within a day. ✓";
            }
            try {
              var src = form.querySelector('input[name="source"]');
              if (window.fbq) { fbq('track', 'Lead', { content_name: (src && src.value) || location.pathname }); }
            } catch (err) {}
            form.reset();
            if (btn) { btn.textContent = "Sent ✓"; }
            var dl = form.querySelector(".lp-download");
            if (dl) { dl.style.display = "block"; }
          }).catch(function () {
            if (status) {
              status.style.display = "block";
              status.style.color = "#b3492e";
              status.textContent = "Something went wrong, email team@22cowork.pt and we'll sort it.";
            }
            if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || "Submit"; }
          });
        });
      });
    })();
  </script>
</body>
</html>
