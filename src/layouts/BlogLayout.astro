---
export interface Props {
  title: string;
  description: string;
  slug: string;            // e.g. "blog/the-future-of-work" or "blog"
  heroImg?: string;        // absolute path like /assets/deepwork.jpg
  heroAlt?: string;
  date?: string;           // ISO, e.g. "2026-07-16"
  readMins?: number;
  category?: string;
  article?: boolean;       // true = blog post (adds Article JSON-LD)
}
const {
  title,
  description,
  slug,
  heroImg,
  heroAlt = "22cowork, Setúbal",
  date,
  readMins,
  category = "Journal",
  article = false,
} = Astro.props;

const SITE = "https://www.22cowork.pt";
const canonical = `${SITE}/${slug.replace(/^\//, "")}`;
const ogImage = heroImg ? `${SITE}${heroImg}` : `${SITE}/assets/hero.jpg`;
const readable = date
  ? new Date(date).toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" })
  : undefined;

const jsonLd = article
  ? {
      "@context": "https://schema.org",
      "@type": "Article",
      headline: title,
      description,
      image: ogImage,
      datePublished: date,
      dateModified: date,
      author: { "@type": "Organization", name: "22cowork" },
      publisher: {
        "@type": "Organization",
        name: "22cowork",
        logo: { "@type": "ImageObject", url: `${SITE}/assets/hero.jpg` },
      },
      mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
    }
  : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-W54DF8WLWQ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-W54DF8WLWQ');
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />

  <meta property="og:type" content={article ? "article" : "website"} />
  <meta property="og:site_name" content="22cowork" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&amp;family=Inter:wght@400;500;600&amp;family=IBM+Plex+Mono:wght@400;500&amp;family=Montserrat:wght@500;600;700&amp;display=swap"
    rel="stylesheet"
  />
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <style is:global>
  :root{
    --paper:#F4F1EA; --paper-2:#ECE8DE; --paper-3:#E3DED2;
    --ink:#171511; --ink-soft:#3A362D; --muted-2:#7D7869;
    --line:rgba(23,21,17,.14); --line-2:rgba(23,21,17,.08);
    --ember:#335C4A; --ember-deep:#294A3B; --contrast:#0B0A08;
    --ease:cubic-bezier(.22,.61,.36,1); --pad:clamp(20px,5vw,88px);
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:"Inter",system-ui,sans-serif;font-size:17px;line-height:1.6;letter-spacing:-.005em;overflow-x:hidden}
  ::selection{background:var(--ink);color:var(--paper)}
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}
  .wrap{max-width:1320px;margin:0 auto;padding:0 var(--pad)}
  .mono{font-family:"IBM Plex Mono",monospace;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2)}
  .label{display:inline-flex;align-items:center;gap:.6em}
  .label::before{content:"";width:16px;height:1px;background:var(--muted-2);display:inline-block}

  /* nav */
  header.nav{position:sticky;top:0;z-index:60;display:flex;align-items:center;justify-content:space-between;padding:15px var(--pad);background:color-mix(in srgb,var(--paper) 86%,transparent);backdrop-filter:saturate(1.2) blur(14px);border-bottom:1px solid var(--line-2)}
  .brand{font-family:"Montserrat",sans-serif;font-weight:700;font-size:1.12rem;letter-spacing:-.01em}
  nav.links{display:flex;gap:28px;align-items:center}
  nav.links a{font-family:"IBM Plex Mono",monospace;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;opacity:.85;transition:opacity .3s}
  nav.links a:hover{opacity:1}
  .nav-cta{border:1px solid var(--ink);border-radius:100px;padding:9px 18px;transition:.3s}
  .nav-cta:hover{background:var(--ember);border-color:var(--ember);color:#F4F1EA}
  @media(max-width:720px){nav.links a:not(.nav-cta){display:none}}

  /* article */
  .post{padding:clamp(30px,5vh,60px) 0 clamp(40px,7vh,80px)}
  .post-head{max-width:760px;margin:0 auto;text-align:center}
  .post-head .meta{justify-content:center;margin-bottom:1.3rem;color:var(--ember-deep)}
  .post-head .meta::before{background:var(--ember-deep)}
  .post h1{font-family:"Fraunces",serif;font-weight:360;letter-spacing:-.022em;line-height:1.05;font-size:clamp(2rem,4.6vw,3.4rem);margin:0}
  .post .dek{font-size:clamp(1.1rem,1.5vw,1.3rem);color:var(--ink-soft);margin:1.2rem auto 0;max-width:60ch}
  .post-hero{max-width:1040px;margin:clamp(28px,5vh,52px) auto 0;aspect-ratio:16/8;overflow:hidden;border-radius:10px;border:1px solid var(--line)}
  .post-hero img{width:100%;height:100%;object-fit:cover}

  .prose{max-width:720px;margin:clamp(30px,5vh,54px) auto 0}
  .prose>*+*{margin-top:1.15em}
  .prose h2{font-family:"Fraunces",serif;font-weight:380;letter-spacing:-.02em;line-height:1.15;font-size:clamp(1.5rem,2.6vw,2.1rem);margin-top:2em}
  .prose h3{font-family:"Fraunces",serif;font-weight:400;font-size:clamp(1.2rem,1.8vw,1.5rem);margin-top:1.5em}
  .prose p{color:var(--ink-soft)}
  .prose strong{color:var(--ink);font-weight:600}
  .prose a{color:var(--ember-deep);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px}
  .prose ul,.prose ol{color:var(--ink-soft);padding-left:1.3em}
  .prose li+li{margin-top:.5em}
  .prose blockquote{margin:1.6em 0;padding-left:1.1em;border-left:2px solid var(--ember);font-family:"Fraunces",serif;font-style:italic;font-size:1.3rem;color:var(--ink)}
  .prose hr{border:0;border-top:1px solid var(--line);margin:2.4em 0}

  /* end CTA */
  .post-cta{max-width:720px;margin:clamp(36px,6vh,64px) auto 0;background:var(--contrast);color:var(--paper);border-radius:12px;padding:clamp(28px,4vw,44px);text-align:center}
  .post-cta h3{font-family:"Fraunces",serif;font-weight:360;font-size:clamp(1.5rem,2.6vw,2.1rem);margin:0 0 .5rem}
  .post-cta p{color:rgba(244,241,234,.72);margin:0 auto 1.6rem;max-width:44ch}
  .btn{font-family:"IBM Plex Mono",monospace;font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;padding:14px 26px;border-radius:100px;border:1px solid;display:inline-flex;gap:.6em;transition:transform .4s var(--ease),background .3s}
  .btn:hover{transform:translateY(-2px)}
  .btn-gold{background:var(--ember);color:#F4F1EA;border-color:var(--ember);font-weight:500}
  .btn-gold:hover{background:#3f7059;border-color:#3f7059}

  /* generic content page (privacy) */
  .doc{max-width:760px;margin:0 auto;padding:clamp(30px,5vh,60px) 0 clamp(40px,7vh,80px)}
  .doc h1{font-family:"Fraunces",serif;font-weight:360;font-size:clamp(2rem,4vw,3rem);letter-spacing:-.02em;margin:0 0 .4rem}
  .doc .upd{color:var(--muted-2);margin-bottom:2rem}
  .doc h2{font-family:"Fraunces",serif;font-weight:380;font-size:clamp(1.3rem,2.2vw,1.7rem);margin-top:2em}
  .doc p,.doc li{color:var(--ink-soft)}
  .doc>*+*{margin-top:1.1em}
  .doc a{color:var(--ember-deep);text-decoration:underline;text-underline-offset:3px}
  .doc ul{padding-left:1.3em}.doc li+li{margin-top:.5em}

  /* blog index */
  .bl-head{max-width:760px;padding:clamp(36px,6vh,72px) 0 clamp(20px,3vh,36px)}
  .bl-head h1{font-family:"Fraunces",serif;font-weight:340;font-size:clamp(2.4rem,5vw,4rem);letter-spacing:-.02em;margin:.4rem 0 0}
  .bl-head p{color:var(--ink-soft);font-size:1.15rem;margin-top:1rem;max-width:52ch}
  .bl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;padding-bottom:clamp(50px,8vh,100px)}
  .bl-card{display:flex;flex-direction:column;background:var(--paper-2);border:1px solid var(--line);border-radius:10px;overflow:hidden;transition:transform .5s var(--ease),box-shadow .5s}
  .bl-card:hover{transform:translateY(-4px);box-shadow:0 30px 60px -44px rgba(23,21,17,.4)}
  .bl-card .thumb{aspect-ratio:16/10;overflow:hidden;background:var(--paper-3)}
  .bl-card .thumb img{width:100%;height:100%;object-fit:cover;transition:transform .8s var(--ease)}
  .bl-card:hover .thumb img{transform:scale(1.045)}
  .bl-card .body{padding:22px 22px 26px;display:flex;flex-direction:column;gap:8px;flex:1}
  .bl-card .cat{font-family:"IBM Plex Mono",monospace;font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;color:var(--ember-deep)}
  .bl-card h2{font-family:"Fraunces",serif;font-weight:380;font-size:1.3rem;line-height:1.18;margin:0}
  .bl-card p{color:var(--ink-soft);font-size:.95rem;flex:1}
  .bl-card .go{font-family:"IBM Plex Mono",monospace;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;color:var(--ink)}
  @media(max-width:900px){.bl-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:600px){.bl-grid{grid-template-columns:1fr}}

  /* footer */
  footer.foot{background:var(--paper);border-top:1px solid var(--line);padding:clamp(44px,6vh,72px) 0 40px}
  footer.foot{background:#294A3B;border-top:none;color:#F4F1EA}
  footer.foot .big-brand{color:#F4F1EA}
  footer.foot h4{color:rgba(244,241,234,.5)}
  footer.foot a{color:rgba(244,241,234,.78)}
  footer.foot a:hover{color:#F4F1EA}
  footer.foot p{color:rgba(244,241,234,.74)!important}
  footer.foot .foot-bottom{border-top-color:rgba(244,241,234,.15)}
  footer.foot .mono{color:rgba(244,241,234,.5)}
  .foot-top{display:grid;grid-template-columns:2fr 1fr 1fr;gap:30px}
  .foot h4{font-family:"IBM Plex Mono",monospace;font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted-2);margin:0 0 14px;font-weight:500}
  .foot a{display:block;font-size:.92rem;color:var(--ink-soft);padding:5px 0}
  .foot a:hover{color:var(--ink)}
  .foot .big-brand{font-family:"Montserrat",sans-serif;font-size:clamp(2rem,5vw,3rem);font-weight:700;letter-spacing:-.02em;line-height:1}
  .foot-bottom{display:flex;justify-content:space-between;margin-top:clamp(34px,5vh,56px);padding-top:22px;border-top:1px solid var(--line-2);flex-wrap:wrap;gap:14px}
  @media(max-width:700px){.foot-top{grid-template-columns:1fr 1fr}}
  </style>
</head>
<body>
  <header class="nav">
    <a href="/" class="brand">22cowork</a>
    <nav class="links">
      <a href="/#spaces">Spaces</a>
      <a href="/blog">Journal</a>
      <a href="/#tour">Tour</a>
      <a href="/#reserve" class="nav-cta">Reserve</a>
    </nav>
  </header>

  <slot />

  <footer class="foot">
    <div class="wrap">
      <div class="foot-top">
        <div>
          <div class="big-brand">22cowork<span style="color:#8FC0A9">.</span></div>
          <p style="max-width:34ch;margin-top:1rem;color:var(--muted-2)">A workspace for founders, creators and freelancers. Setúbal, Portugal. 35 minutes from Lisboa.</p>
        </div>
        <div>
          <h4>Space</h4>
          <a href="/#spaces">Spaces</a><a href="/#work">A day here</a><a href="/blog">Journal</a><a href="/#reserve">Reserve</a>
        </div>
        <div>
          <h4>Legal</h4>
          <a href="/privacy">Privacy Policy</a><a href="https://instagram.com/22cowork" target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
      <div class="foot-bottom">
        <span class="mono">© 2026 22cowork · Setúbal, Portugal</span>
        <span class="mono">Built simple. Made to last.</span>
      </div>
    </div>
  </footer>
</body>
</html>
