  .wa{position:fixed; bottom:22px; right:22px; z-index:70; width:56px; height:56px; border-radius:50%; background:var(--ink); color:var(--paper); display:flex; align-items:center; justify-content:center; box-shadow:0 14px 40px -12px rgba(23,21,17,.6); transition:transform .4s var(--ease), background .3s}
