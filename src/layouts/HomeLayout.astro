  .stars{color:var(--ember); font-size:.92rem; letter-spacing:1px}
  .gr-txt{font-family:"IBM Plex Mono",monospace; font-size:.64rem; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-soft)}
  .gr-txt b{font-family:"Fraunces",serif; font-weight:500; font-size:1.05rem; letter-spacing:0}
  .foot-rating{margin-top:1.2rem}
  .trust .resv{font-family:"IBM Plex Mono",monospace; font-size:.68rem; letter-spacing:.11em; text-transform:uppercase; color:var(--ember-deep); display:inline-flex; align-items:center; gap:8px; white-space:nowrap}
  .trust .resv .dot{width:7px;height:7px;border-radius:50%;background:var(--ember);box-shadow:0 0 0 0 rgba(225,167,48,.6);animation:pulse 2.4s infinite}
  @media(max-width:680px){.trust .wrap{gap:14px} .trust .stat b{font-size:1.1rem}}

  .spaces{background:var(--paper-2); border-top:1px solid var(--line-2)}
  .spaces-head{display:grid; grid-template-columns:1fr 1.12fr; gap:clamp(28px,4vw,56px); align-items:center; margin-bottom:clamp(28px,4.5vh,52px)}
  .sh-text{max-width:34ch}
  .sh-video .video-frame{margin-top:0}
  @media(max-width:820px){.spaces-head{grid-template-columns:1fr; gap:22px} .sh-text{max-width:none}}
  .sp-grid{display:grid; grid-template-columns:repeat(6,1fr); gap:16px; margin-top:clamp(26px,4vh,44px)}
  .sp-card{grid-column:span 2; background:var(--paper); border:1px solid var(--line); border-radius:8px; overflow:hidden; display:flex; flex-direction:column; transition:transform .5s var(--ease), box-shadow .5s var(--ease)}
  .sp-card:hover{transform:translateY(-4px); box-shadow:0 32px 60px -42px rgba(23,21,17,.45)}
  .sp-card.feat{grid-column:span 3}
  .sp-media{position:relative; aspect-ratio:16/10; overflow:hidden; background:var(--paper-3)}
  .sp-card.feat .sp-media{aspect-ratio:16/8}
  .sp-media img{width:100%;height:100%;object-fit:cover; transition:transform .8s var(--ease)}
  .sp-card:hover .sp-media img{transform:scale(1.045)}
  .sp-badge{position:absolute; top:12px; left:12px; font-family:"IBM Plex Mono",monospace; font-size:.56rem; letter-spacing:.12em; text-transform:uppercase; background:var(--ember); color:#1a1305; padding:5px 10px; border-radius:100px}
  .sp-badge.soft{background:color-mix(in srgb,var(--paper) 86%,transparent); color:var(--ink-soft); backdrop-filter:blur(4px)}
  .sp-body{padding:22px 22px 24px; display:flex; flex-direction:column; gap:7px; flex:1}
  .sp-body .lbl{font-family:"IBM Plex Mono",monospace; font-size:.6rem; letter-spacing:.14em; text-transform:uppercase; color:var(--muted-2)}
  .sp-body h3{font-size:clamp(1.25rem,1.7vw,1.7rem)}
  .sp-body p{color:var(--ink-soft); font-size:.96rem; flex:1}
  .sp-go{margin-top:8px; font-family:"IBM Plex Mono",monospace; font-size:.7rem; letter-spacing:.1em; text-transform:uppercase; color:var(--ink); display:inline-flex; gap:.55em; align-items:center; transition:gap .35s var(--ease), color .3s}
  .sp-card:hover .sp-go{gap:1.1em; color:var(--ember-deep)}
  @media(max-width:900px){.sp-grid{grid-template-columns:repeat(2,1fr)} .sp-card,.sp-card.feat{grid-column:span 1} .sp-card.feat .sp-media{aspect-ratio:16/10}}
  @media(max-width:560px){.sp-grid{grid-template-columns:1fr}}

  .resv-tags{display:flex; flex-wrap:wrap; gap:10px; margin-top:1.8rem}
  .resv-tags .t{font-family:"IBM Plex Mono",monospace; font-size:.62rem; letter-spacing:.1em; text-transform:uppercase; color:rgba(244,241,234,.75); border:1px solid rgba(244,241,234,.22); border-radius:100px; padding:8px 13px; display:inline-flex; gap:8px; align-items:center}
  .resv-tags .t .dot{width:6px;height:6px;border-radius:50%;background:var(--ember)}

  .prog{position:fixed; top:0; left:0; height:2px; background:var(--ember); z-index:80; width:0}
  </style>
</head>
<body>
  <div class="prog" id="prog"></div>

  <slot />

  <a class="wa" href="https://wa.me/351913781095" target="_blank" rel="noopener" aria-label="WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.15-1.7-.85-2-.94-.26-.1-.45-.15-.64.15s-.74.94-.9 1.13c-.17.2-.34.22-.63.08-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.6.13-.14.3-.34.44-.51.15-.17.2-.3.3-.5.1-.19.05-.36-.02-.5-.08-.16-.64-1.55-.88-2.12-.23-.55-.47-.48-.64-.49h-.55c-.19 0-.5.07-.76.36-.26.3-1 .98-1 2.4s1.02 2.78 1.16 2.97c.15.2 2.02 3.08 4.9 4.32.68.3 1.22.47 1.63.6.69.22 1.31.19 1.8.11.55-.08 1.7-.69 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.26-.19-.55-.34zM12 2a10 10 0 00-8.6 15.06L2 22l5.06-1.33A10 10 0 1012 2z"/></svg>
  </a>

  <script>
    // graceful image fallback: hide a broken <img> so the clean placeholder shows.
    document.querySelectorAll("img").forEach((img) => {
      img.addEventListener("error", () => { img.style.display = "none"; });
    });

    // scroll reveal
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
    }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
    document.querySelectorAll(".rise").forEach((el) => io.observe(el));

    // nav state + reading progress
    const nav = document.getElementById("nav");
    const prog = document.getElementById("prog");
    const onScroll = () => {
      const y = window.scrollY;
      if (nav) nav.classList.toggle("solid", y > window.innerHeight * 0.7);
      const h = document.documentElement.scrollHeight - window.innerHeight;
      if (prog) prog.style.width = (y / h) * 100 + "%";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    // rotating hero headline — cycles the italic clause with a typewriter feel
    const rot = document.getElementById("rot");
    if (rot && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
      const phrases = ["ship, not sit.", "mean business.", "build things that last.", "skip the theatre.", "create real value."];
      let pi = 0, ci = phrases[0].length, deleting = true;
      const step = () => {
        const p = phrases[pi];
        if (!deleting) {
          ci++; rot.textContent = p.slice(0, ci);
          if (ci >= p.length) { deleting = true; return setTimeout(step, 2100); }
        } else {
          ci--; rot.textContent = p.slice(0, ci);
          if (ci <= 0) { deleting = false; pi = (pi + 1) % phrases.length; return setTimeout(step, 260); }
        }
        setTimeout(step, deleting ? 48 : 90);
      };
      setTimeout(step, 2100);
    }

    // click-to-play tour (loads the YouTube iframe only on demand)
    const tv = document.getElementById("tour-video");
    const play = tv && tv.querySelector(".vplay");
    if (play) {
      play.addEventListener("click", () => {
        const id = tv.getAttribute("data-yt");
        tv.innerHTML = '<iframe src="https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0&modestbranding=1&playsinline=1" title="22cowork office tour" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>';
      });
    }

    // reserve form — native, single screen, posts straight into GoHighLevel
    // via an Inbound Webhook (no API key in the browser). Paste your GHL
    // inbound webhook URL below and the form is live.
    const GHL_WEBHOOK = "REPLACE_WITH_GHL_INBOUND_WEBHOOK_URL";
    const leadForm = document.getElementById("lead-form");
    if (leadForm) {
      const status = document.getElementById("form-status");
      const btn = leadForm.querySelector('button[type="submit"]');
      const btnLabel = btn ? btn.textContent : "";
      const say = (msg, ok) => {
        if (!status) return;
        status.style.display = "block";
        status.style.color = ok ? "var(--ember)" : "#e0897a";
        status.textContent = msg;
      };
      leadForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(leadForm).entries());
        data.source = "22cowork.pt homepage";
        if (!GHL_WEBHOOK || GHL_WEBHOOK.indexOf("REPLACE") === 0) {
          say("Form isn't connected yet. Please email team@22cowork.pt.", false);
          return;
        }
        if (btn) { btn.disabled = true; btn.textContent = "Sending…"; }
        if (status) status.style.display = "none";
        try {
          await fetch(GHL_WEBHOOK, {
            method: "POST",
            mode: "no-cors",
            body: new URLSearchParams(data),
          });
          leadForm.reset();
          if (btn) btn.textContent = "Reserved ✓";
          say("Thanks, we'll confirm within a day.", true);
        } catch (err) {
          if (btn) { btn.disabled = false; btn.textContent = btnLabel; }
          say("Couldn't send just now. Please email team@22cowork.pt.", false);
        }
      });
    }
  </script>
</body>
</html>
