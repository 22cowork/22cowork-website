---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "22cowork — Setúbal",
  description = "A workspace built the way you'd build a product. Setúbal, 20 minutes from Lisboa.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&amp;family=Inter:wght@400;500;600&amp;family=IBM+Plex+Mono:wght@400;500&amp;family=Montserrat:wght@500;600;700&amp;display=swap"
    rel="stylesheet"
  />
  <style is:global>
  /* ============================================================
     22cowork — editorial identity
     Palette: warm paper, warm ink. Black only for contrast.
     Type: Fraunces (editorial display) / Inter (voice) / Plex Mono (signature)
     ============================================================ */
  :root{
    --paper:#F4F1EA;        /* warm white */
    --paper-2:#ECE8DE;      /* soft off-white */
    --paper-3:#E3DED2;      /* light gray-sand */
    --ink:#171511;          /* warm near-black */
    --ink-soft:#3A362D;     /* graphite */
    --muted:#8B857642;      /* hairline base */
    --muted-2:#7D7869;      /* muted text */
    --line:rgba(23,21,17,.14);
    --line-2:rgba(23,21,17,.08);
    --ember:#e1a730;        /* 22cowork gold — the one signature accent, used sparingly */
    --ember-deep:#a97d18;   /* darker gold for small text on light backgrounds */
    --contrast:#0B0A08;     /* black, for max-contrast panels only */
    --ease:cubic-bezier(.22,.61,.36,1);
    --ease-out:cubic-bezier(.16,1,.3,1);
    --pad: clamp(20px, 5vw, 88px);
  }

  *{box-sizing:border-box}
  html{scroll-behavior:smooth; -webkit-font-smoothing:antialiased; text-rendering:optimizeLegibility}
  body{
    margin:0; background:var(--paper); color:var(--ink);
    font-family:"Inter",system-ui,sans-serif;
    font-size:clamp(15px,1.05vw,17px); line-height:1.55;
    letter-spacing:-0.005em;
    overflow-x:hidden;
  }
  ::selection{background:var(--ink); color:var(--paper)}
  a{color:inherit; text-decoration:none}
  img,video{display:block; max-width:100%}

  .wrap{max-width:1320px; margin:0 auto; padding-left:var(--pad); padding-right:var(--pad)}

  /* ---------- signature type primitives ---------- */
  .mono{font-family:"IBM Plex Mono",monospace; font-size:.72rem; letter-spacing:.16em; text-transform:uppercase; color:var(--muted-2)}
  .label{display:inline-flex; align-items:center; gap:.6em}
  .label::before{content:""; width:16px; height:1px; background:var(--muted-2); display:inline-block}
  .cursor{display:inline-block; width:.52em; height:1.05em; background:var(--ember); margin-left:.12em; transform:translateY(.13em); animation:blink 1.1s steps(1) infinite}
  @keyframes blink{50%{opacity:0}}

  .serif{font-family:"Fraunces",Georgia,serif; font-weight:340; letter-spacing:-.02em; line-height:1.02}
  h1,h2,h3{font-family:"Fraunces",Georgia,serif; font-weight:360; letter-spacing:-.022em; line-height:1.03; margin:0}
  .display{font-size:clamp(2.6rem,7vw,6.4rem); font-weight:330}
  .h2{font-size:clamp(2rem,4.4vw,4rem); font-weight:350; line-height:1.02}
  .h3{font-size:clamp(1.3rem,2vw,1.9rem); font-weight:380}
  em{font-style:italic}

  /* ---------- reveal ---------- */
  .rise{opacity:0; transform:translateY(26px); transition:opacity 1s var(--ease-out), transform 1.1s var(--ease-out)}
  .rise.in{opacity:1; transform:none}
  .rise[data-d="1"]{transition-delay:.08s}
  .rise[data-d="2"]{transition-delay:.16s}
  .rise[data-d="3"]{transition-delay:.24s}
  @media (prefers-reduced-motion:reduce){.rise{opacity:1;transform:none;transition:none} .cursor{animation:none}}

  /* ============================================================ NAV */
  header.nav{
    position:fixed; top:0; left:0; right:0; z-index:60;
    display:flex; align-items:center; justify-content:space-between;
    padding:18px var(--pad);
    transition:background .5s var(--ease), border-color .5s, padding .4s;
    border-bottom:1px solid transparent;
    mix-blend-mode:difference; color:#fff;
  }
  header.nav.solid{
    mix-blend-mode:normal; color:var(--ink);
    background:color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter:saturate(1.2) blur(14px);
    border-bottom:1px solid var(--line-2);
    padding-top:13px; padding-bottom:13px;
  }
  .brand{font-family:"Montserrat",sans-serif; font-weight:700; font-size:1.12rem; letter-spacing:-.01em; display:flex; align-items:baseline; gap:.05em}
  .brand b{font-weight:700}
  .brand .b-cur{width:.42em; height:.95em; background:currentColor; display:inline-block; transform:translateY(.06em); margin-left:.14em; animation:blink 1.1s steps(1) infinite}
  nav.links{display:flex; gap:30px; align-items:center}
  nav.links a{font-family:"IBM Plex Mono",monospace; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; opacity:.85; transition:opacity .3s}
  nav.links a:hover{opacity:1}
  .nav-cta{border:1px solid currentColor; border-radius:100px; padding:9px 18px !important; opacity:1 !important; transition:background .3s,color .3s}
  header.nav.solid .nav-cta:hover{background:var(--ink); color:var(--paper)}
  header.nav:not(.solid) .nav-cta:hover{background:#fff; color:#000}
  .burger{display:none}
  @media(max-width:860px){
    nav.links{display:none}
    .burger{display:block; font-family:"IBM Plex Mono",monospace; font-size:.72rem; letter-spacing:.12em; text-transform:uppercase; border:1px solid currentColor; border-radius:100px; padding:8px 15px}
  }

  /* ============================================================ HERO */
  .hero{position:relative; min-height:100svh; display:flex; align-items:flex-end; overflow:hidden; background:var(--contrast)}
  .hero video, .hero .fallback{position:absolute; inset:0; width:100%; height:100%; object-fit:cover}
  .hero .fallback{z-index:0; background:linear-gradient(140deg,#2a2620,#0c0b09 70%); display:flex; align-items:center; justify-content:center}
  .hero video{z-index:1}
  .hero .scrim{position:absolute; inset:0; z-index:1;
    background:linear-gradient(180deg, rgba(8,7,6,.42) 0%, rgba(8,7,6,.12) 34%, rgba(8,7,6,.14) 60%, rgba(8,7,6,.72) 100%)}
  .hero-inner{position:relative; z-index:2; color:#F4F1EA; width:100%; padding-bottom:clamp(40px,7vh,90px)}
  .hero .display{max-width:16ch; margin-top:.2em}
  .hero .sub{max-width:46ch; margin-top:1.4rem; font-size:clamp(1rem,1.25vw,1.18rem); color:rgba(244,241,234,.82); line-height:1.5}
  .hero-top{position:relative; z-index:2; flex:1; display:flex; align-items:flex-start; padding-top:clamp(96px,14vh,150px)}
  .hero-top .mono{color:rgba(244,241,234,.72)}
  .hero-top .mono::before{background:rgba(244,241,234,.6)}
  .hero-actions{display:flex; gap:14px; margin-top:2.2rem; flex-wrap:wrap}
  .btn{font-family:"IBM Plex Mono",monospace; font-size:.75rem; letter-spacing:.1em; text-transform:uppercase; padding:14px 26px; border-radius:100px; border:1px solid; transition:transform .4s var(--ease), background .3s, color .3s; display:inline-flex; align-items:center; gap:.7em}
  .btn:hover{transform:translateY(-2px)}
  .btn-solid{background:#F4F1EA; color:#0B0A08; border-color:#F4F1EA}
  .btn-ghost{background:transparent; color:#F4F1EA; border-color:rgba(244,241,234,.4)}
  .btn-ghost:hover{border-color:#F4F1EA}
  .btn-ink{background:var(--ink); color:var(--paper); border-color:var(--ink)}
  .btn-ink:hover{background:var(--ember); border-color:var(--ember)}
  .btn-outline{background:transparent; color:var(--ink); border-color:var(--line)}
  .btn-outline:hover{border-color:var(--ink)}
  .scroll-cue{position:absolute; bottom:26px; right:var(--pad); z-index:3; color:rgba(244,241,234,.7); writing-mode:vertical-rl; font-family:"IBM Plex Mono",monospace; font-size:.66rem; letter-spacing:.24em; text-transform:uppercase; display:flex; align-items:center; gap:12px}
  .scroll-cue .ln{width:1px; height:46px; background:linear-gradient(rgba(244,241,234,.7),transparent); animation:drop 2.2s var(--ease) infinite}
  @keyframes drop{0%{transform:scaleY(0);transform-origin:top}45%{transform:scaleY(1);transform-origin:top}55%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

  /* marquee spec strip under hero */
  .ticker{border-top:1px solid var(--line); border-bottom:1px solid var(--line); background:var(--paper-2); overflow:hidden; white-space:nowrap}
  .ticker .run{display:inline-flex; gap:56px; padding:16px 0; animation:slide 34s linear infinite; will-change:transform}
  .ticker span{font-family:"IBM Plex Mono",monospace; font-size:.74rem; letter-spacing:.14em; text-transform:uppercase; color:var(--ink-soft); display:inline-flex; gap:56px}
  .ticker span::after{content:"—"; color:var(--ember)}
  @keyframes slide{to{transform:translateX(-50%)}}

  /* ============================================================ SECTION scaffolding */
  section{position:relative}
  .band{padding:clamp(80px,13vh,170px) 0}
  .eyebrow{margin-bottom:2.4rem}
  .lead{font-size:clamp(1.15rem,1.5vw,1.35rem); line-height:1.5; color:var(--ink-soft); max-width:40ch}

  /* ---------- manifesto ---------- */
  .manifesto{background:var(--paper); border-bottom:1px solid var(--line-2)}
  .manifesto .quote{font-family:"Fraunces",serif; font-weight:330; font-size:clamp(2.1rem,5.2vw,4.6rem); line-height:1.04; letter-spacing:-.025em; max-width:20ch}
  .manifesto .quote .em{font-style:italic; color:var(--ember)}
  .manifesto .foot{margin-top:2.4rem; display:flex; gap:40px; flex-wrap:wrap; max-width:60ch; color:var(--muted-2); font-size:1rem}

  /* ---------- workday narrative ---------- */
  .day{background:var(--paper-2); border-top:1px solid var(--line-2)}
  .day .head{display:flex; justify-content:space-between; align-items:flex-end; gap:20px; flex-wrap:wrap; margin-bottom:clamp(40px,7vh,90px)}
  .moment{
    display:grid; grid-template-columns: 1fr 1.05fr; gap:clamp(24px,4vw,72px);
    align-items:center; padding:clamp(40px,7vh,84px) 0; border-top:1px solid var(--line);
  }
  .moment:nth-child(even){grid-template-columns:1.05fr 1fr}
  .moment:nth-child(even) .m-text{order:2}
  .moment:nth-child(even) .m-media{order:1}
  .m-text .time{font-family:"IBM Plex Mono",monospace; font-size:.78rem; letter-spacing:.14em; color:var(--ember-deep); margin-bottom:1.1rem}
  .m-text h3{font-size:clamp(1.7rem,3.2vw,2.9rem); margin-bottom:.7rem}
  .m-text p{max-width:34ch; color:var(--ink-soft); font-size:1.05rem}
  .m-media{position:relative}
  .slot{position:relative; aspect-ratio:4/3.1; border-radius:6px; overflow:hidden; background:
      repeating-linear-gradient(45deg,var(--paper-3),var(--paper-3) 12px,var(--paper-2) 12px,var(--paper-2) 24px);
      border:1px solid var(--line); display:flex; align-items:flex-end}
  .slot img{position:absolute; inset:0; width:100%; height:100%; object-fit:cover}
  .slot .tag{position:relative; z-index:1; margin:14px; font-family:"IBM Plex Mono",monospace; font-size:.64rem; letter-spacing:.12em; text-transform:uppercase; color:var(--muted-2); background:color-mix(in srgb,var(--paper) 80%,transparent); padding:6px 10px; border-radius:4px; backdrop-filter:blur(4px)}
  .slot.tall{aspect-ratio:3/4}
  @media(max-width:760px){
    .moment,.moment:nth-child(even){grid-template-columns:1fr; gap:24px}
    .moment:nth-child(even) .m-text{order:1}.moment:nth-child(even) .m-media{order:2}
  }

  /* ---------- three kinds of work ---------- */
  .kinds{background:var(--paper); border-top:1px solid var(--line-2)}
  .kgrid{display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--line); border:1px solid var(--line); border-radius:6px; overflow:hidden; margin-top:clamp(40px,6vh,72px)}
  .kcard{background:var(--paper); padding:clamp(28px,3vw,44px); min-height:340px; display:flex; flex-direction:column; justify-content:space-between; transition:background .5s var(--ease)}
  .kcard:hover{background:var(--paper-2)}
  .kcard .n{font-family:"IBM Plex Mono",monospace; font-size:.72rem; letter-spacing:.14em; color:var(--ember-deep)}
  .kcard h3{font-size:clamp(1.4rem,2vw,1.9rem); margin:1.6rem 0 .8rem}
  .kcard p{color:var(--ink-soft); font-size:1rem; max-width:30ch}
  @media(max-width:820px){.kgrid{grid-template-columns:1fr}}

  /* ---------- spec sheet (museum plaque) ---------- */
  .spec{background:var(--contrast); color:var(--paper)}
  .spec .wrap{padding-top:clamp(80px,13vh,150px); padding-bottom:clamp(80px,13vh,150px)}
  .spec .mono{color:rgba(244,241,234,.6)} .spec .mono::before{background:rgba(244,241,234,.4)}
  .spec h2{color:var(--paper)}
  .spec .status{float:right; font-family:"IBM Plex Mono",monospace; font-size:.68rem; letter-spacing:.14em; color:#7fae7a; display:inline-flex; align-items:center; gap:8px}
  .spec .status .dot{width:7px;height:7px;border-radius:50%;background:#7fae7a;box-shadow:0 0 0 0 rgba(127,174,122,.6);animation:pulse 2.4s infinite}
  @keyframes pulse{70%{box-shadow:0 0 0 8px rgba(127,174,122,0)}100%{box-shadow:0 0 0 0 rgba(127,174,122,0)}}
  .sheet{margin-top:clamp(40px,6vh,72px); border-top:1px solid rgba(244,241,234,.18)}
  .row{display:grid; grid-template-columns:150px 1fr auto; gap:24px; align-items:baseline; padding:20px 0; border-bottom:1px solid rgba(244,241,234,.12); transition:padding-left .4s var(--ease)}
  .row:hover{padding-left:10px}
  .row .k{font-family:"IBM Plex Mono",monospace; font-size:.72rem; letter-spacing:.14em; text-transform:uppercase; color:rgba(244,241,234,.55)}
  .row .v{font-family:"Fraunces",serif; font-size:clamp(1.05rem,1.5vw,1.4rem); font-weight:360; color:var(--paper)}
  .row .m{font-family:"IBM Plex Mono",monospace; font-size:.66rem; letter-spacing:.1em; color:rgba(244,241,234,.4)}
  @media(max-width:680px){.row{grid-template-columns:1fr; gap:6px}.row .m{display:none}}

  /* ---------- invisible technology ---------- */
  .tech{background:var(--paper); border-top:1px solid var(--line-2); overflow:hidden}
  .tech .big{font-family:"Fraunces",serif; font-weight:330; font-size:clamp(2rem,4.6vw,4rem); line-height:1.05; letter-spacing:-.025em; max-width:18ch}
  .tech .big .fade{color:var(--muted-2)}
  .chips{display:flex; flex-wrap:wrap; gap:10px; margin-top:clamp(36px,5vh,60px); max-width:760px}
  .chip{font-family:"IBM Plex Mono",monospace; font-size:.7rem; letter-spacing:.1em; text-transform:uppercase; color:var(--muted-2); border:1px solid var(--line); border-radius:100px; padding:9px 15px; transition:.4s var(--ease)}
  .chip:hover{color:var(--ink); border-color:var(--ink); transform:translateY(-2px)}

  /* ---------- tour ---------- */
  .tour{background:var(--paper-2); border-top:1px solid var(--line-2)}
  .video-frame{margin-top:clamp(40px,6vh,64px); position:relative; aspect-ratio:16/9; border-radius:8px; overflow:hidden; border:1px solid var(--line); background:#000; box-shadow:0 40px 90px -50px rgba(23,21,17,.5)}
  .video-frame iframe{position:absolute; inset:0; width:100%; height:100%; border:0}

  /* ---------- community ---------- */
  .comm{background:var(--paper); border-top:1px solid var(--line-2)}
  .comm-grid{display:grid; grid-template-columns:1.1fr 1fr; gap:clamp(30px,5vw,70px); align-items:center}
  .ig{display:grid; grid-template-columns:repeat(3,1fr); gap:8px}
  .ig .slot{aspect-ratio:1; border-radius:4px}
  @media(max-width:760px){.comm-grid{grid-template-columns:1fr}}

  /* ---------- contact ---------- */
  .contact{background:var(--contrast); color:var(--paper)}
  .contact .wrap{padding:clamp(80px,13vh,160px) var(--pad)}
  .contact .mono{color:rgba(244,241,234,.6)} .contact .mono::before{background:rgba(244,241,234,.4)}
  .contact h2{color:var(--paper); max-width:16ch}
  .contact .grid{display:grid; grid-template-columns:1fr 1fr; gap:clamp(30px,5vw,80px); margin-top:clamp(40px,6vh,70px)}
  .contact p.lead{color:rgba(244,241,234,.72)}
  form{display:grid; gap:18px}
  .f2{display:grid; grid-template-columns:1fr 1fr; gap:18px}
  .field{position:relative}
  .field input,.field select{width:100%; background:transparent; border:0; border-bottom:1px solid rgba(244,241,234,.28); color:var(--paper); font-family:"Inter",sans-serif; font-size:1rem; padding:12px 0; outline:none; transition:border-color .3s}
  .field select{color:rgba(244,241,234,.7)}
  .field input::placeholder{color:rgba(244,241,234,.4)}
  .field input:focus,.field select:focus{border-color:var(--ember)}
  .field label{font-family:"IBM Plex Mono",monospace; font-size:.62rem; letter-spacing:.14em; text-transform:uppercase; color:rgba(244,241,234,.5); display:block; margin-bottom:2px}
  option{color:#000}
  @media(max-width:680px){.contact .grid,.f2{grid-template-columns:1fr}}

  /* ---------- footer ---------- */
  footer.foot{background:var(--paper); border-top:1px solid var(--line); padding:clamp(50px,7vh,80px) 0 40px}
  .foot-top{display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:30px}
  .foot h4{font-family:"IBM Plex Mono",monospace; font-size:.66rem; letter-spacing:.16em; text-transform:uppercase; color:var(--muted-2); margin:0 0 16px; font-weight:500}
  .foot a{display:block; font-size:.92rem; color:var(--ink-soft); padding:5px 0; transition:color .3s}
  .foot a:hover{color:var(--ink)}
  .foot .big-brand{font-family:"Montserrat",sans-serif; font-size:clamp(2.2rem,5.4vw,3.8rem); font-weight:700; letter-spacing:-.02em; line-height:1}
  .foot-bottom{display:flex; justify-content:space-between; align-items:center; margin-top:clamp(40px,6vh,70px); padding-top:24px; border-top:1px solid var(--line-2); flex-wrap:wrap; gap:16px}
  .foot-bottom .mono{font-size:.66rem}
  @media(max-width:760px){.foot-top{grid-template-columns:1fr 1fr}}

  /* whatsapp float */
  .wa{position:fixed; bottom:22px; right:22px; z-index:70; width:56px; height:56px; border-radius:50%; background:var(--ink); color:var(--paper); display:flex; align-items:center; justify-content:center; box-shadow:0 14px 40px -12px rgba(23,21,17,.6); transition:transform .4s var(--ease), background .3s}
  .wa:hover{transform:scale(1.06); background:var(--ember)}
  .wa svg{width:26px;height:26px}

  /* progress line */
  .prog{position:fixed; top:0; left:0; height:2px; background:var(--ember); z-index:80; width:0}
  </style>
</head>
<body>
  <div class="prog" id="prog"></div>

  <slot />

  <!-- whatsapp -->
  <a class="wa" href="https://wa.me/351913781095" target="_blank" rel="noopener" aria-label="WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.15-1.7-.85-2-.94-.26-.1-.45-.15-.64.15s-.74.94-.9 1.13c-.17.2-.34.22-.63.08-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.6.13-.14.3-.34.44-.51.15-.17.2-.3.3-.5.1-.19.05-.36-.02-.5-.08-.16-.64-1.55-.88-2.12-.23-.55-.47-.48-.64-.49h-.55c-.19 0-.5.07-.76.36-.26.3-1 .98-1 2.4s1.02 2.78 1.16 2.97c.15.2 2.02 3.08 4.9 4.32.68.3 1.22.47 1.63.6.69.22 1.31.19 1.8.11.55-.08 1.7-.69 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.26-.19-.55-.34zM12 2a10 10 0 00-8.6 15.06L2 22l5.06-1.33A10 10 0 1012 2z"/></svg>
  </a>

  <script>
    // graceful image fallback — hide a broken <img> so the elegant
    // striped placeholder + caption shows instead.
    document.querySelectorAll("img").forEach((img) => {
      img.addEventListener("error", () => { (img as HTMLElement).style.display = "none"; });
    });

    // scroll reveal
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
    document.querySelectorAll(".rise").forEach((el) => io.observe(el));

    // nav state + reading progress
    const nav = document.getElementById("nav");
    const prog = document.getElementById("prog");
    const onScroll = () => {
      const y = window.scrollY;
      nav?.classList.toggle("solid", y > window.innerHeight * 0.7);
      const h = document.documentElement.scrollHeight - window.innerHeight;
      if (prog) prog.style.width = (y / h) * 100 + "%";
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    // book-a-visit form — confirmation only (no backend wired yet)
    const bookForm = document.getElementById("book-form");
    bookForm?.addEventListener("submit", (e) => {
      e.preventDefault();
      const btn = bookForm.querySelector("button");
      if (btn) btn.textContent = "Sent — talk soon ✓";
    });
  </script>
</body>
</html>
