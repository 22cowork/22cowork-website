---
import { colors } from '@/config/colors';

const navItems = [
  { label: 'O Espaço', href: '/space' },
  { label: 'Inteligência', href: '/intelligence' },
  { label: 'Membros', href: '/memberships' },
  { label: 'Comunidade', href: '/community' },
];
---

<nav class="sticky top-0 z-50 border-b" style={{ borderColor: colors.border, backgroundColor: colors.background }}>
  <div class="container flex items-center justify-between py-4">
    <a href="/" class="font-display font-bold text-2xl" style={{ color: colors.primary }}>
      22Cowork
    </a>
    <ul class="hidden md:flex gap-8">
      {navItems.map((item) => (
        <li>
          <a href={item.href} style={{ color: colors.foreground }} class="hover:text-primary transition-colors">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="/book" class="px-6 py-2 rounded-lg font-medium transition-all" style={{ backgroundColor: colors.primary, color: colors['primary-foreground'] }}>
      Agendar
    </a>
  </div>
</nav>
