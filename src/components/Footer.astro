---
import { siteMetadata, navigationLinks } from "../config/content";

const currentYear = new Date().getFullYear();
---

<footer class="bg-soft-off-white text-text-dark-gray py-12 mt-20">
  <div class="container grid grid-cols-1 md:grid-cols-4 gap-8">
    <div>
      <a href="/" class="flex items-center space-x-2 mb-4">
        <img src="/assets/logo.svg" alt="22Cowork Logo" class="h-8" />
        <span class="font-display text-xl font-bold text-text-black">{siteMetadata.title.split(" · ")[0]}</span>
      </a>
      <p class="text-sm">
        {siteMetadata.description}
      </p>
    </div>
    <div>
      <h4 class="font-display font-semibold text-text-black mb-4">Navigation</h4>
      <ul class="space-y-2 text-sm">
        {navigationLinks.map((link) => (
          <li>
            <a href={link.href} class="hover:text-forest-green transition-colors duration-300">
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <h4 class="font-display font-semibold text-text-black mb-4">Connect</h4>
      <ul class="space-y-2 text-sm">
        <li>
          <a href={siteMetadata.social.instagram} target="_blank" rel="noopener noreferrer" class="hover:text-forest-green transition-colors duration-300">
            Instagram
          </a>
        </li>
        <li>
          <a href={siteMetadata.social.youtube} target="_blank" rel="noopener noreferrer" class="hover:text-forest-green transition-colors duration-300">
            YouTube
          </a>
        </li>
        <li>
          <a href={siteMetadata.social.whatsapp} target="_blank" rel="noopener noreferrer" class="hover:text-forest-green transition-colors duration-300">
            WhatsApp
          </a>
        </li>
        <li>
          <a href="mailto:{siteMetadata.social.email}" class="hover:text-forest-green transition-colors duration-300">
            Email
          </a>
        </li>
      </ul>
    </div>
    <div>
      <h4 class="font-display font-semibold text-text-black mb-4">Location</h4>
      <p class="text-sm">
        Rua do Comércio, 22<br />
        2900-000 Setúbal, Portugal
      </p>
      <a href="https://maps.app.goo.gl/YOUR_GOOGLE_MAPS_LINK" target="_blank" rel="noopener noreferrer" class="text-sm text-forest-green hover:underline mt-2 block">
        Get Directions
      </a>
    </div>
  </div>
  <div class="border-t border-light-gray pt-8 mt-8">
    <p class="text-sm text-center">
      &copy; {currentYear} {siteMetadata.title.split(" · ")[0]}. All rights reserved.
    </p>
  </div>
</footer>
